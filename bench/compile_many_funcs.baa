    س = ف25(س).
    س = ف26(س).
    س = ف27(س).
    س = ف28(س).
    س = ف29(س).
    إرجع س.
}

صحيح الرئيسية() {
    مصيدة = سلسلة(0).
    إرجع 0.
}
