صحيح سلسلة(صحيح س) {
    س = ف0(س).
    س = ف1(س).
    س = ف2(س).
    س = ف3(س).
    س = ف4(س).
    س = ف5(س).
    س = ف6(س).
    س = ف7(س).
    س = ف8(س).
    س = ف9(س).
    س = ف10(س).
    س = ف11(س).
    س = ف12(س).
