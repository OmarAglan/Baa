صحيح مصيدة = 0.

صحيح مزج(صحيح س, صحيح ص) {
    إرجع (س * 33) + ص.
}

صحيح مزج_1(صحيح س) {
    إرجع مزج(س, 7).
}

صحيح مزج_2(صحيح س) {
    إرجع مزج(س, 11).
}

صحيح الرئيسية() {
    صحيح مجموع = 0.
    صحيح ع = 0.

    طالما (ع < 2000000) {
        إذا ((ع % 2) == 0) {
            مجموع = مجموع + مزج_1(ع).
        } وإلا {
            مجموع = مجموع + مزج_2(ع).
        }
        ع = ع + 1.
    }

    مصيدة = مجموع.
    إرجع 0.
}
