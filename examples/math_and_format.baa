#تضمين "stdlib/baalib.baahd"

صحيح الرئيسية() {
    عشري زاوية = ٠.٥.
    عشري ج = جيب(زاوية).
    عشري م = جيب_تمام(زاوية).

    نص س١ = نسق("جيب=%.4ع جيب_تمام=%.4ع", ج, م).
    نص س2 = نسق("جيب بصيغة علمية: %.6أ", ج).

    إذا (س١ != عدم) {
        اطبع س١.
        حرر_نص(س١).
    }
    إذا (س2 != عدم) {
        اطبع س2.
        حرر_نص(س2).
    }

    إرجع ٠.
}
