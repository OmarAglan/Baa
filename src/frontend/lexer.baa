    }
    إذا (طولقيمة == طول_خام(خام"حالة") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"حالة")) {
        إرجع ٣٧.
    }
    إذا (طولقيمة == طول_خام(خام"افتراضي") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"افتراضي")) {
