    }
    إذا (طولقيمة == طول_خام(خام"افتراضي") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"افتراضي")) {
        إرجع ٣٨.
    }
    إذا (طولقيمة == طول_خام(خام"صواب") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"صواب")) {
        إرجع ٣٩.
    }
    إذا (طولقيمة == طول_خام(خام"خطأ") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"خطأ")) {
