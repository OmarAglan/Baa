#تضمين "stdlib/baalib.baahd"
#تضمين "lexer_state_baa0.baahd"

ط٨* حالةمصدر.
صحيح حالةطول = ٠.
صحيح حالةموضع = ٠.
صحيح حالةسطر = ١.
صحيح حالةعمود = ١.
صحيح قبليةعدد = ٠.
ط٨* قبليةبداية[8].
صحيح قبليةطول[8].
ط٨* قبليةقيمة[8].
صحيح قبليةطول_قيمة[8].
صحيح قبليةنمط_قيمة[8].
صحيح قبليةعمق = ٠.
صحيح قبليةاصل[8].
صحيح قبليةتحقق[8].
صحيح قبليةفرع_اخر[8].
صحيح قبليةحد = ٨.
ط٨* حالةمصدر_مكدس[8].
صحيح حالةطول_مكدس[8].
صحيح حالةموضع_مكدس[8].
صحيح حالةسطر_مكدس[8].
صحيح حالةعمود_مكدس[8].
صحيح حالةعمق_مصادر = ٠.
صحيح حالةتشخيص_رمز = ٠.
صحيح حالةتشخيص_سطر = ٠.
صحيح حالةتشخيص_عمود = ٠.
صحيح حالةتشخيص_طول = ١.

عدم حالةسجل_تشخيص(صحيح رمز، صحيح طول) {
    إذا (حالةتشخيص_رمز == ٠) {
        حالةتشخيص_رمز = رمز.
        حالةتشخيص_سطر = حالةسطر.
        حالةتشخيص_عمود = حالةعمود.
        حالةتشخيص_طول = طول.
    }
}

عدم حالةسجل_تشخيص_عند(صحيح رمز، صحيح موضع، صحيح طول) {
    إذا (حالةتشخيص_رمز == ٠) {
        صحيح مؤشر = حالةموضع.
        صحيح سطر_محسوب = حالةسطر.
        صحيح عمود_محسوب = حالةعمود.
        طالما (مؤشر < موضع) {
            إذا (حالةبايت(مؤشر) == ١٠) {
                سطر_محسوب = سطر_محسوب + ١.
                عمود_محسوب = ١.
            } وإلا {
                عمود_محسوب = عمود_محسوب + ١.
            }
            مؤشر = مؤشر + ١.
        }
        حالةتشخيص_رمز = رمز.
        حالةتشخيص_سطر = سطر_محسوب.
        حالةتشخيص_عمود = عمود_محسوب.
        حالةتشخيص_طول = طول.
    }
}

منطقي حالةتابع_يوتي_عند(صحيح موضع) {
    صحيح بايت = حالةبايت(موضع).
    إرجع بايت >= ١٢٨ && بايت <= ١٩١.
}

صحيح حالةطول_يوتي_عند(صحيح موضع) {
    صحيح بايت = حالةبايت(موضع).
    إذا (بايت > ٠ && بايت <= ١٢٧) {
        إرجع ١.
    }
    إذا (بايت >= ١٩٤ && بايت <= ٢٢٣ && حالةتابع_يوتي_عند(موضع + ١)) {
        إرجع ٢.
    }
    إذا (بايت >= ٢٢٤ && بايت <= ٢٣٩ && حالةتابع_يوتي_عند(موضع + ١) && حالةتابع_يوتي_عند(موضع + ٢)) {
        إرجع ٣.
    }
    إذا (بايت >= ٢٤٠ && بايت <= ٢٤٤ && حالةتابع_يوتي_عند(موضع + ١) && حالةتابع_يوتي_عند(موضع + ٢) && حالةتابع_يوتي_عند(موضع + ٣)) {
        إرجع ٤.
    }
    إرجع ٠.
}

صحيح حالةطول_هروب_مدعوم_عند(صحيح موضع) {
    صحيح بايت = حالةبايت(موضع).
    إذا (بايت == ٣٤ || بايت == ٣٩ || بايت == ٩٢) {
        إرجع ١.
    }
    إذا (بايت == ٢١٦ && (حالةبايت(موضع + ١) == ١٧٩ || حالةبايت(موضع + ١) == ١٧٠ || حالةبايت(موضع + ١) == ١٧٧)) {
        إرجع ٢.
    }
    إذا (بايت == ٢١٧ && حالةبايت(موضع + ١) == ١٦٠) {
        إرجع ٢.
    }
    إرجع ٠.
}

صحيح حالةبايت(صحيح موضع) {
    إذا (حالةمصدر == عدم) {
        إرجع ٠.
    }
    إذا (موضع < ٠ || موضع >= حالةطول) {
        إرجع ٠.
    }
    إرجع *(حالةمصدر + موضع).
}

منطقي حالةيطابق(صحيح طول، ط٨* قالب) {
    إرجع قارن_خام_بطول(حالةمصدر + حالةموضع، طول، قالب).
}

منطقي حالةيطابق_عند(صحيح موضع، صحيح طول، ط٨* قالب) {
    إرجع قارن_خام_بطول(حالةمصدر + موضع، طول، قالب).
}

منطقي حالةفراغ(صحيح بايت) {
    إرجع بايت == ٣٢ || بايت == ٩ || بايت == ١٠ || بايت == ١٣.
}

منطقي حالةرقم_لاتيني(صحيح بايت) {
    إرجع بايت >= ٤٨ && بايت <= ٥٧.
}

منطقي حالةرقم_هندي_عند(صحيح موضع) {
    إرجع حالةبايت(موضع) == ٢١٧ && حالةبايت(موضع + ١) >= ١٦٠ && حالةبايت(موضع + ١) <= ١٦٩.
}

منطقي حالةبداية_معرف_عند(صحيح موضع) {
    صحيح بايت = حالةبايت(موضع).
    إرجع بايت >= ٢١٦ && بايت <= ٢١٩.
}

منطقي حالةتعليق_سطر() {
    إرجع حالةبايت(حالةموضع) == ٤٧ && حالةبايت(حالةموضع + ١) == ٤٧.
}

منطقي حالةفاصل_عند(صحيح موضع) {
    صحيح بايت = حالةبايت(موضع).
    إذا (بايت == ٠ || حالةفراغ(بايت)) {
        إرجع صواب.
    }
    إذا (بايت == ٣٤ || بايت == ٣٥ || بايت == ٣٧ || بايت == ٣٨ || بايت == ٤٠ || بايت == ٤١) {
        إرجع صواب.
    }
    إذا (بايت == ٤٢ || بايت == ٤٣ || بايت == ٤٤ || بايت == ٤٥ || بايت == ٤٦ || بايت == ٤٧) {
        إرجع صواب.
    }
    إذا (بايت == ٥٨ || بايت == ٦٠ || بايت == ٦١ || بايت == ٦٢ || بايت == ٩١ || بايت == ٩٣) {
        إرجع صواب.
    }
    إذا (بايت == ٩٤ || بايت == ١٢٣ || بايت == ١٢٤ || بايت == ١٢٥ || بايت == ١٢٦) {
        إرجع صواب.
    }
    إذا (بايت == ٢١٦ && حالةبايت(موضع + ١) == ١٥٥) {
        إرجع صواب.
    }
    إذا (بايت == ٢١٦ && حالةبايت(موضع + ١) == ١٤٠) {
        إرجع صواب.
    }
    إرجع خطأ.
}

صحيح حالةطول_عدد() {
    صحيح موضع = حالةموضع.
    طالما (حالةرقم_لاتيني(حالةبايت(موضع)) || حالةرقم_هندي_عند(موضع)) {
        إذا (حالةرقم_هندي_عند(موضع)) {
            موضع = موضع + ٢.
        } وإلا {
            موضع = موضع + ١.
        }
    }
    إرجع موضع - حالةموضع.
}

صحيح حالةطول_رقم(صحيح* نوع_رقم) {
    صحيح موضع = حالةموضع.
    *نوع_رقم = ١.
    طالما (حالةرقم_لاتيني(حالةبايت(موضع)) || حالةرقم_هندي_عند(موضع)) {
        إذا (حالةرقم_هندي_عند(موضع)) {
            موضع = موضع + ٢.
        } وإلا {
            موضع = موضع + ١.
        }
    }
    إذا (حالةبايت(موضع) == ٤٦ && (حالةرقم_لاتيني(حالةبايت(موضع + ١)) || حالةرقم_هندي_عند(موضع + ١))) {
        *نوع_رقم = ٢.
        موضع = موضع + ١.
        طالما (حالةرقم_لاتيني(حالةبايت(موضع)) || حالةرقم_هندي_عند(موضع)) {
            إذا (حالةرقم_هندي_عند(موضع)) {
                موضع = موضع + ٢.
            } وإلا {
                موضع = موضع + ١.
            }
        }
    }
    إرجع موضع - حالةموضع.
}

صحيح حالةطول_نص() {
    إرجع حالةطول_نص_عند(حالةموضع، ٨، ٩).
}

صحيح حالةطول_نص_عند(صحيح بداية_اقتباس، صحيح رمز_هروب، صحيح رمز_غير_مغلق) {
    صحيح موضع = بداية_اقتباس + ١.
    طالما (موضع < حالةطول && حالةبايت(موضع) != ٠ && حالةبايت(موضع) != ٣٤) {
        إذا (حالةبايت(موضع) == ٩٢) {
            صحيح طول_هروب = ٠.
            موضع = موضع + ١.
            إذا (حالةبايت(موضع) == ٠) {
                حالةسجل_تشخيص_عند(رمز_غير_مغلق، موضع، ١).
                إرجع موضع - بداية_اقتباس.
            }
            طول_هروب = حالةطول_هروب_مدعوم_عند(موضع).
            إذا (طول_هروب == ٠) {
                حالةسجل_تشخيص_عند(رمز_هروب، موضع، ١).
                إرجع موضع - بداية_اقتباس + ١.
            }
            موضع = موضع + طول_هروب.
        } وإلا إذا (حالةبايت(موضع) >= ١٢٨) {
            صحيح طول_يوتي = حالةطول_يوتي_عند(موضع).
            إذا (طول_يوتي == ٠) {
                حالةسجل_تشخيص_عند(١٢، موضع، ١).
                إرجع موضع - بداية_اقتباس + ١.
            }
            موضع = موضع + طول_يوتي.
        } وإلا {
            موضع = موضع + ١.
        }
    }
    إذا (حالةبايت(موضع) == ٣٤) {
        موضع = موضع + ١.
    } وإلا {
        حالةسجل_تشخيص_عند(رمز_غير_مغلق، موضع، ١).
    }
    إرجع موضع - بداية_اقتباس.
}

صحيح حالةطول_حرف(صحيح* بداية_القيمة، صحيح* طول_القيمة) {
    صحيح موضع = حالةموضع + ١.
    صحيح طول_هروب = ٠.
    صحيح طول_يوتي = ٠.
    *بداية_القيمة = موضع.
    *طول_القيمة = ٠.
    إذا (حالةبايت(موضع) == ٠ || حالةبايت(موضع) == ١٠) {
        حالةسجل_تشخيص_عند(١١، موضع، ١).
        إرجع موضع - حالةموضع.
    }
    إذا (حالةبايت(موضع) == ٩٢) {
        موضع = موضع + ١.
        إذا (حالةبايت(موضع) == ٠ || حالةبايت(موضع) == ١٠) {
            حالةسجل_تشخيص_عند(١١، موضع، ١).
            إرجع موضع - حالةموضع.
        }
        طول_هروب = حالةطول_هروب_مدعوم_عند(موضع).
        إذا (طول_هروب == ٠) {
            حالةسجل_تشخيص_عند(١٠، موضع، ١).
            إرجع موضع - حالةموضع + ١.
        }
        *بداية_القيمة = موضع.
        *طول_القيمة = طول_هروب.
        موضع = موضع + طول_هروب.
    } وإلا {
        طول_يوتي = حالةطول_يوتي_عند(موضع).
        إذا (طول_يوتي == ٠) {
            حالةسجل_تشخيص_عند(١٣، موضع، ١).
            إرجع موضع - حالةموضع + ١.
        }
        *بداية_القيمة = موضع.
        *طول_القيمة = طول_يوتي.
        موضع = موضع + طول_يوتي.
    }
    إذا (حالةبايت(موضع) != ٣٩) {
        حالةسجل_تشخيص_عند(١١، موضع، ١).
        إرجع موضع - حالةموضع + ١.
    }
    إرجع موضع + ١ - حالةموضع.
}

صحيح حالةطول_معرف() {
    صحيح موضع = حالةموضع.
    طالما (!حالةفاصل_عند(موضع)) {
        موضع = موضع + ١.
    }
    إرجع موضع - حالةموضع.
}

منطقي حالةمدى_يطابق(صحيح بداية_أ، صحيح طول_أ، صحيح بداية_ب، صحيح طول_ب) {
    صحيح مؤشر = ٠.
    إذا (طول_أ != طول_ب) {
        إرجع خطأ.
    }
    طالما (مؤشر < طول_أ) {
        إذا (حالةبايت(بداية_أ + مؤشر) != حالةبايت(بداية_ب + مؤشر)) {
            إرجع خطأ.
        }
        مؤشر = مؤشر + ١.
    }
    إرجع صواب.
}

منطقي حالةمدى_مؤشر_يطابق(ط٨* بداية_أ، صحيح طول_أ، ط٨* بداية_ب، صحيح طول_ب) {
    صحيح مؤشر = ٠.
    إذا (بداية_أ == عدم || بداية_ب == عدم) {
        إرجع خطأ.
    }
    إذا (طول_أ != طول_ب) {
        إرجع خطأ.
    }
    طالما (مؤشر < طول_أ) {
        إذا (*(بداية_أ + مؤشر) != *(بداية_ب + مؤشر)) {
            إرجع خطأ.
        }
        مؤشر = مؤشر + ١.
    }
    إرجع صواب.
}

صحيح حالةنوع_معرف(صحيح بداية، صحيح طولقيمة) {
    إذا (طولقيمة == طول_خام(خام"صحيح") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"صحيح")) {
        إرجع ٦.
    }
    إذا (طولقيمة == طول_خام(خام"ص٨") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"ص٨")) {
        إرجع ٧.
    }
    إذا (طولقيمة == طول_خام(خام"ص١٦") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"ص١٦")) {
        إرجع ٨.
    }
    إذا (طولقيمة == طول_خام(خام"ص٣٢") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"ص٣٢")) {
        إرجع ٩.
    }
    إذا (طولقيمة == طول_خام(خام"ص٦٤") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"ص٦٤")) {
        إرجع ١٠.
    }
    إذا (طولقيمة == طول_خام(خام"ط٨") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"ط٨")) {
        إرجع ١١.
    }
    إذا (طولقيمة == طول_خام(خام"ط١٦") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"ط١٦")) {
        إرجع ١٢.
    }
    إذا (طولقيمة == طول_خام(خام"ط٣٢") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"ط٣٢")) {
        إرجع ١٣.
    }
    إذا (طولقيمة == طول_خام(خام"ط٦٤") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"ط٦٤")) {
        إرجع ١٤.
    }
    إذا (طولقيمة == طول_خام(خام"نص") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"نص")) {
        إرجع ١٥.
    }
    إذا (طولقيمة == طول_خام(خام"منطقي") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"منطقي")) {
        إرجع ١٦.
    }
    إذا (طولقيمة == طول_خام(خام"حرف") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"حرف")) {
        إرجع ١٧.
    }
    إذا (طولقيمة == طول_خام(خام"عشري") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"عشري")) {
        إرجع ١٨.
    }
    إذا (طولقيمة == طول_خام(خام"عشري٣٢") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"عشري٣٢")) {
        إرجع ١٩.
    }
    إذا (طولقيمة == طول_خام(خام"عدم") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"عدم")) {
        إرجع ٢٠.
    }
    إذا (طولقيمة == طول_خام(خام"كـ") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"كـ")) {
        إرجع ٢١.
    }
    إذا (طولقيمة == طول_خام(خام"حجم") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"حجم")) {
        إرجع ٢٢.
    }
    إذا (طولقيمة == طول_خام(خام"ثابت") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"ثابت")) {
        إرجع ٢٤.
    }
    إذا (طولقيمة == طول_خام(خام"ساكن") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"ساكن")) {
        إرجع ٢٥.
    }
    إذا (طولقيمة == طول_خام(خام"إرجع") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"إرجع")) {
        إرجع ٢٦.
    }
    إذا (طولقيمة == طول_خام(خام"اطبع") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"اطبع")) {
        إرجع ٢٧.
    }
    إذا (طولقيمة == طول_خام(خام"اقرأ") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"اقرأ")) {
        إرجع ٢٨.
    }
    إذا (طولقيمة == طول_خام(خام"مجمع") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"مجمع")) {
        إرجع ٢٩.
    }
    إذا (طولقيمة == طول_خام(خام"إذا") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"إذا")) {
        إرجع ٣٠.
    }
    إذا (طولقيمة == طول_خام(خام"وإلا") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"وإلا")) {
        إرجع ٣١.
    }
    إذا (طولقيمة == طول_خام(خام"طالما") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"طالما")) {
        إرجع ٣٢.
    }
    إذا (طولقيمة == طول_خام(خام"لكل") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"لكل")) {
        إرجع ٣٣.
    }
    إذا (طولقيمة == طول_خام(خام"توقف") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"توقف")) {
        إرجع ٣٤.
    }
    إذا (طولقيمة == طول_خام(خام"استمر") && قارن_خام_بطول(حالةمصدر + بداية، طولقيمة، خام"استمر")) {
