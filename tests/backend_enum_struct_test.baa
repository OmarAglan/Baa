تعداد لون {
    أحمر،
    أزرق،
    أسود،
    أبيض،
}

هيكل محرك {
    صحيح قوة.
}

هيكل سيارة {
    نص موديل.
    صحيح سنة_الصنع.
    تعداد لون لون_السيارة.
    هيكل محرك محرك_السيارة.
}

// اختبار متغير عام من نوع هيكل (صفر-تهيئة)
هيكل محرك محرك_عام.

صحيح الرئيسية() {
    هيكل سيارة س.

    س:موديل = "تويوتا".
    س:سنة_الصنع = ٢٠٢٤.
    س:لون_السيارة = لون:أحمر.
    س:محرك_السيارة:قوة = ١٥٠.

    محرك_عام:قوة = ٧.

    إذا (س:سنة_الصنع != ٢٠٢٤) { إرجع ١. }
    إذا (س:محرك_السيارة:قوة != ١٥٠) { إرجع ٢. }
    إذا (محرك_عام:قوة != ٧) { إرجع ٣. }

    إذا (س:لون_السيارة == لون:أحمر) {
        // OK
    } وإلا {
        إرجع ٤.
    }

    // مقارنة تعداد بنوع مختلف يجب أن تُرفض (نغطيها باختبار سلبي منفصل)
    إرجع ٠.
}
