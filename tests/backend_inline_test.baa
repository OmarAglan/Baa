// ============================================================================
// اختبار التضمين (Inlining) — v0.3.2.7.2
// ============================================================================
// الهدف:
// - التأكد من أن -O2 يقوم بتضمين دالة صغيرة ذات موقع نداء واحد.
// - التحقق من صحة النتيجة عند التشغيل.
//
// التشغيل:
//   build\baa.exe -O2 tests\backend_inline_test.baa -o build\backend_inline_test.exe -v
//   build\backend_inline_test.exe
// ============================================================================

صحيح تحقق(صحيح فعلي, صحيح متوقع) {
    إذا (فعلي != متوقع) {
        اطبع "FAIL".
        إرجع 1.
    }
    إرجع 0.
}

// يجب أن تكون صغيرة وبموقع نداء واحد
صحيح زائد_واحد(صحيح س) {
    إرجع س + 1.
}

صحيح الرئيسية() {
    صحيح س = 41.
    صحيح ن = زائد_واحد(س).
    صحيح خ = تحقق(ن, 42).
    إذا (خ == 0) {
        اطبع "PASS".
    }
    إرجع خ.
}
