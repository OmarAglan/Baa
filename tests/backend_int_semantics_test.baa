// اختبار دلالات الأعداد الصحيحة (ترقيات/تحويلات/موقّع-غير موقّع) — v0.3.5.5

صحيح عد = ٠.

صحيح تحقق(صحيح فعلي, صحيح متوقع) {
    عد = عد + ١.
    إذا (فعلي != متوقع) {
        اطبع "فشل تحقق:".
        اطبع عد.
        إرجع ١.
    }
    إرجع ٠.
}

// تهيئة عامة: يجب أن تُقتطع إلى 32-بت (ط٣٢) عند الإصدار.
ط٣٢ التفاف_عام_ط٣٢ = ٤٢٩٤٩٦٧٢٩٥ + ١.

صحيح اختبار_ترقيات_ومقارنات() {
    صحيح خ = ٠.

    // i32 sign-extend عند التحويل إلى صحيح/ص٦٤
    ص٣٢ س = -١.
    صحيح س٦٤ = س.
    خ = خ + تحقق(س٦٤, -١).

    // u32 zero-extend عند التحويل إلى صحيح/ص٦٤
    ط٣٢ ت = ٤٢٩٤٩٦٧٢٩٥.
    صحيح ت٦٤ = ت.
    خ = خ + تحقق(ت٦٤, ٤٢٩٤٩٦٧٢٩٥).

    // مقارنة موقّع/غير موقّع على 32-بت: يجب أن تصبح غير موقّعة.
    ط٣٢ غير_موقّع = ١.
    ص٣٢ موقّع = -١.
    صحيح ن١ = (غير_موقّع < موقّع).
    صحيح ن٢ = (غير_موقّع > موقّع).
    خ = خ + تحقق(ن١, ١).
    خ = خ + تحقق(ن٢, ٠).

    // مزج u32 مع i64: i64 يستطيع تمثيل كل u32 → التحويل يكون إلى i64.
    صحيح س_كبير = -١.
    صحيح ن٣ = (ت > س_كبير).
    خ = خ + تحقق(ن٣, ١).

    // دلالة ترقيم/تحويلات ثابتات: 2147483647 + 1 ضمن ص٣٢ → يلتف إلى -2147483648.
    صحيح ل = ٢١٤٧٤٨٣٦٤٧ + ١.
    خ = خ + تحقق(ل, -٢١٤٧٤٨٣٦٤٨).

    // ترقيات i8/u8 إلى ص٣٢ قبل الحساب.
    ط٨ ط٢٥٠ = ٢٥٠.
    ص٨ ص_سالب١ = -١.
    صحيح م = ط٢٥٠ + ص_سالب١.
    خ = خ + تحقق(م, ٢٤٩).

    // مقارنة بعد الترقيات (signed): 250 > -1
    صحيح م٢ = (ط٢٥٠ > ص_سالب١).
    خ = خ + تحقق(م٢, ١).

    // u32 + i32 => u32 (عند نفس الرتبة، signed لا يغطي كل u32)
    ط٣٢ كبير = ٤٠٠٠٠٠٠٠٠٠.
    ص٣٢ ناقص٢ = -٢.
    صحيح ج = كبير + ناقص٢.
    خ = خ + تحقق(ج, ٣٩٩٩٩٩٩٩٩٨).

    // مقارنة i32 مع u32 تتحول إلى u32: (-1 < 1) تصبح (4294967295 < 1) => خطأ
    ص٣٢ سالب١_٣٢ = -١.
    ط٣٢ واحد_٣٢ = ١.
    صحيح م٣ = (سالب١_٣٢ < واحد_٣٢).
    خ = خ + تحقق(م٣, ٠).

    // قسمة/باقي signed نحو الصفر.
    ص٣٢ س٥ = -٥.
    ص٣٢ س٢ = ٢.
    ص٣٢ ق = س٥ / س٢.
    ص٣٢ ب = س٥ % س٢.
    خ = خ + تحقق(ق, -٢).
    خ = خ + تحقق(ب, -١).

    // قسمة/باقي unsigned.
    ط٣٢ ط٥ = ٥.
    ط٣٢ ط٢ = ٢.
    ط٣٢ ق٢ = ط٥ / ط٢.
    ط٣٢ ب٢ = ط٥ % ط٢.
    خ = خ + تحقق(ق٢, ٢).
    خ = خ + تحقق(ب٢, ١).

    // تحقق من التهيئة العامة المُقتطعة.
    خ = خ + تحقق(التفاف_عام_ط٣٢, ٠).

    // طباعة بعض القيم للتأكد من عدم الانهيار (لا نتحقق من النص).
    اطبع ت.
    اطبع س.

    إرجع خ.
}

صحيح الرئيسية() {
    صحيح خ = ٠.
    خ = خ + اختبار_ترقيات_ومقارنات().
    إذا (خ == ٠) {
        اطبع "PASS".
    } وإلا {
        اطبع "FAIL".
    }
    إرجع خ.
}
