// ============================================================================
// اختبار النداء_الذيلي (Tail Call Optimization) — v0.3.2.7.3 / v0.3.2.8.5
// ============================================================================
// الهدف:
// - التأكد من أن -O2 يحول نمط (نداء ثم رجوع) إلى قفز_ذيلي،
//   مما يمنع انفجار المكدس في العودية العميقة.
//
// التشغيل:
//   build\baa.exe -O2 tests\backend_tailcall_test.baa -o build\backend_tailcall_test.exe -v
//   build\backend_tailcall_test.exe
// ============================================================================

صحيح تحقق(صحيح فعلي, صحيح متوقع) {
    إذا (فعلي != متوقع) {
        اطبع "FAIL".
        إرجع 1.
    }
    إرجع 0.
}

// دالة "هوية" بسيطة. نستخدمها مرتين كي لا تُضمّن (heuristic: single call site only).
صحيح هوية(صحيح س) {
    إرجع س.
}

// مجموع_ذيلي(n, acc) = 1 + 2 + ... + n
// هذه دالة عودية ذيلية: آخر تعبير هو نداء لنفس الدالة.
صحيح مجموع_ذيلي(صحيح ن, صحيح م) {
    إذا (ن == 0) {
        إرجع م.
    }
    إرجع مجموع_ذيلي(ن - 1, م + ن).
}

// اختبار tailcall مع معاملات مكدس (يتجاوز معاملات السجلات على Windows/SysV)
صحيح عد_ذيلي٨(صحيح ن, صحيح ا, صحيح ب, صحيح ج, صحيح د, صحيح هـ, صحيح و, صحيح ز, صحيح ح) {
    إذا (ن == 0) {
        إرجع ا + ب + ج + د + هـ + و + ز + ح.
    }
    // النداء الأخير (tail position)
    إرجع عد_ذيلي٨(ن - 1, ا + 1, ب, ج, د, هـ, و, ز, ح).
}

صحيح الرئيسية() {
    صحيح ن = هوية(200000).
    صحيح صفر = هوية(0).
    صحيح فعلي = مجموع_ذيلي(ن, 0).

    // نتجنب ثابتاً كبيراً لأن محلل الأرقام لديه حدود حالياً.
    صحيح متوقع = (ن * (ن + 1)) / 2 + صفر.
    صحيح خ = تحقق(فعلي, متوقع).
    إذا (خ == 0) {
        اطبع "PASS".
    }

    // عمق عودية كبير لتأكيد TCO حتى مع معاملات مكدس
    صحيح ر2 = عد_ذيلي٨(200000, 0, 1, 2, 3, 4, 5, 6, 7).
    إذا (ر2 != (200000 + 1 + 2 + 3 + 4 + 5 + 6 + 7)) {
        اطبع "FAIL".
        إرجع 1.
    }

    إرجع خ.
}
