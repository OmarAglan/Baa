// ============================================================================
// اختبار النداء_الذيلي (Tail Call Optimization) — v0.3.2.7.3
// ============================================================================
// الهدف:
// - التأكد من أن -O2 يحول نمط (نداء ثم رجوع) إلى قفز_ذيلي،
//   مما يمنع انفجار المكدس في العودية العميقة.
//
// التشغيل:
//   build\baa.exe -O2 tests\backend_tailcall_test.baa -o build\backend_tailcall_test.exe -v
//   build\backend_tailcall_test.exe
// ============================================================================

صحيح تحقق(صحيح فعلي, صحيح متوقع) {
    إذا (فعلي != متوقع) {
        اطبع "FAIL".
        إرجع 1.
    }
    إرجع 0.
}

// مجموع_ذيلي(n, acc) = 1 + 2 + ... + n
// هذه دالة عودية ذيلية: آخر تعبير هو نداء لنفس الدالة.
صحيح مجموع_ذيلي(صحيح ن, صحيح م) {
    إذا (ن == 0) {
        إرجع م.
    }
    إرجع مجموع_ذيلي(ن - 1, م + ن).
}

صحيح الرئيسية() {
    صحيح ن = 65000.
    صحيح فعلي = مجموع_ذيلي(ن, 0).

    // n*(n+1)/2 = 2112532500
    صحيح خ = تحقق(فعلي, 2112532500).
    إذا (خ == 0) {
        اطبع "PASS".
    }
    إرجع خ.
}
