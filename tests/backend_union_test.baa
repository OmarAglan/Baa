تعداد نوع_قيمة {
    رقم،
    نص_ق،
}

اتحاد قيمة {
    صحيح رقم.
    نص نص_قيمة.
}

هيكل قيمة_موسومة {
    تعداد نوع_قيمة نوع.
    اتحاد قيمة بيانات.
}

صحيح الرئيسية() {
    اتحاد قيمة ق.
    ق:رقم = ٤٢.
    إذا (ق:رقم != ٤٢) { إرجع ١. }

    // الكتابة إلى عضو آخر تُبدّل نفس الذاكرة (لا نتحقق من القراءة بعد overwrite هنا).
    ق:نص_قيمة = "مرحبا".

    هيكل قيمة_موسومة م.
    م:نوع = نوع_قيمة:رقم.
    م:بيانات:رقم = ٩.
    إذا (م:بيانات:رقم != ٩) { إرجع ٢. }

    م:نوع = نوع_قيمة:نص_ق.
    م:بيانات:نص_قيمة = "توكن".

    اطبع م:بيانات:نص_قيمة.
    إرجع ٠.
}
