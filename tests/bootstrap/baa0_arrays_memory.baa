// RUN: expect-pass runtime

صحيح افحص_مصفوفة(صحيح* قيم) {
    صحيح م = 0.
    صحيح مجموع = 0.

    طالما (م < 4) {
        مجموع = مجموع + *(قيم + م).
        م = م + 1.
    }

    إرجع مجموع.
}

صحيح الرئيسية() {
    صحيح محلية[4] = {1، 2، 3، 4}.
    إذا (افحص_مصفوفة(&محلية[0]) != 10) {
        إرجع 1.
    }

    صحيح* مخزن = حجز_ذاكرة(4 * حجم(صحيح)).
    إذا (مخزن == عدم) {
        إرجع 2.
    }

    تعيين_ذاكرة(مخزن، 0، 4 * حجم(صحيح)).
    *(مخزن + 0) = 6.
    *(مخزن + 1) = 7.
    *(مخزن + 2) = 8.
    *(مخزن + 3) = 9.

    إذا (افحص_مصفوفة(مخزن) != 30) {
        تحرير_ذاكرة(مخزن).
        إرجع 3.
    }

    تحرير_ذاكرة(مخزن).
    إرجع 0.
}
