// RUN: expect-pass runtime

#تعريف حد_اختبار 5

صحيح جمع_حتى(صحيح حد) {
    صحيح مجموع = 0.
    صحيح م = 0.

    طالما (م < حد) {
        م = م + 1.
        إذا (م == 3) {
            استمر.
        }
        مجموع = مجموع + م.
    }

    إرجع مجموع.
}

صحيح الرئيسية() {
    صحيح نتيجة = جمع_حتى(حد_اختبار).
    إذا (نتيجة != 12) {
        إرجع 1.
    }
    إرجع 0.
}
