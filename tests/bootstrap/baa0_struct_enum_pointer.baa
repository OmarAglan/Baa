// RUN: expect-pass runtime

#تضمين "tests/bootstrap/baa0_header.baahd"

صحيح دالة_رأسية(صحيح س) {
    إرجع س + 7.
}

صحيح مجموع_قيم(صحيح أول, صحيح ثاني) {
    إرجع أول + ثاني.
}

صحيح الرئيسية() {
    هيكل زوج_صحيح ز.
    ز:أول = 11.
    ز:ثاني = 13.

    إذا (مجموع_قيم(ز:أول, ز:ثاني) != 24) {
        إرجع 1.
    }
    إذا (دالة_رأسية(5) != 12) {
        إرجع 2.
    }
    إذا (حالة_مصغرة:حالة_واحد != 1) {
        إرجع 3.
    }
    إرجع 0.
}
