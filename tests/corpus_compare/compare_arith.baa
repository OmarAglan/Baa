صحيح تحقق(صحيح حصل, صحيح متوقع) {
    إذا (حصل != متوقع) {
        إرجع 1.
    }
    إرجع 0.
}

صحيح الرئيسية() {
    صحيح س = 0.
    صحيح ع = 0.

    طالما (ع < 100000) {
        س = س + (ع * 3).
        س = س - (س / 7).
        إذا (س < 0) {
            س = -س.
        }
        ع = ع + 1.
    }

    // تحقق بسيط لثبات السلوك: نعيد حساب نسخة مختصرة.
    صحيح س2 = 0.
    صحيح ب = 0.
    طالما (ب < 100000) {
        س2 = س2 + (ب * 3).
        س2 = س2 - (س2 / 7).
        إذا (س2 < 0) { س2 = -س2. }
        ب = ب + 1.
    }

    إذا (تحقق(س, س2) != 0) {
        إرجع 2.
    }

    إرجع 0.
}
