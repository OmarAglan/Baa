صحيح د(صحيح أ, صحيح ب, صحيح ج, صحيح د) {
    إرجع (أ * 7) + (ب * 11) + (ج * 13) + (د * 17).
}

صحيح الرئيسية() {
    صحيح س = 0.
    صحيح ع = 0.

    طالما (ع < 200000) {
        س = س + د(ع, 1, 2, 3).
        س = س - د(ع, 3, 2, 1).
        ع = ع + 1.
    }

    إذا (س == 42) {
        إرجع 3.
    }
    إرجع 0.
}
