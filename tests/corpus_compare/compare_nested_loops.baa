صحيح الرئيسية() {
    صحيح س = 0.
    صحيح ع = 0.
    طالما (ع < 200) {
        صحيح ب = 0.
        طالما (ب < 200) {
            إذا (((ع + ب) % 3) == 0) {
                س = س + 1.
            } وإلا {
                س = س + 2.
            }
            اختر ((ع + ب) % 4) {
                حالة 0:
                    س = س + 3.
                    توقف.
                حالة 1:
                    س = س - 1.
                    توقف.
                افتراضي:
                    س = س + 0.
                    توقف.
            }
            ب = ب + 1.
        }
        ع = ع + 1.
    }

    إذا (س == 0) {
        إرجع 2.
    }
    إرجع 0.
}
