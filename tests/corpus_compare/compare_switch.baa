صحيح الرئيسية() {
    صحيح س = 0.
    صحيح ع = 0.

    طالما (ع < 200000) {
        اختر (ع % 5) {
            حالة 0:
                س = س + 1.
                توقف.
            حالة 1:
                س = س + 2.
                توقف.
            حالة 2:
                س = س - 3.
                توقف.
            حالة 3:
                س = س + (ع / 7).
                توقف.
            افتراضي:
                س = س + (س % 11).
                توقف.
        }
        ع = ع + 1.
    }

    // شرط نهائي لتفادي التحسينات التي قد تسقط المسار (مصيدة منطقية).
    إذا (س == 123456789) {
        إرجع 9.
    }

    إرجع 0.
}
