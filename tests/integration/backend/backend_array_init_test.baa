صحيح الرئيسية() {
    // تهيئة جزئية (الفاصلة العربية)
    صحيح أ[٥] = {١، ٢}.

    إذا (أ[٠] != ١) { إرجع ١. }
    إذا (أ[١] != ٢) { إرجع ٢. }
    إذا (أ[٢] != ٠) { إرجع ٣. }
    إذا (أ[٣] != ٠) { إرجع ٤. }
    إذا (أ[٤] != ٠) { إرجع ٥. }

    // تهيئة فارغة {} (كلها أصفار) — مثل C
    صحيح ب[٣] = {}.
    إذا (ب[٠] != ٠) { إرجع ٦. }
    إذا (ب[١] != ٠) { إرجع ٧. }
    إذا (ب[٢] != ٠) { إرجع ٨. }

    // تهيئة كاملة (الفاصلة العادية)
    صحيح ج[٤] = {١, ٢, ٣, ٤}.
    إذا (ج[٠] != ١) { إرجع ٩. }
    إذا (ج[١] != ٢) { إرجع ١٠. }
    إذا (ج[٢] != ٣) { إرجع ١١. }
    إذا (ج[٣] != ٤) { إرجع ١٢. }

    إرجع ٠.
}
