صحيح الرئيسية() {
    صحيح فشل = ٠.

    صحيح أ[٥].
    صحيح ب[٢][٣].

    صحيح طول_أ = حجم(أ) / حجم(صحيح).
    صحيح طول_ب = حجم(ب) / حجم(صحيح).

    إذا (طول_أ != ٥) {
        اطبع "فشل: طول_أ".
        فشل = فشل + ١.
    }

    إذا (طول_ب != ٦) {
        اطبع "فشل: طول_ب".
        فشل = فشل + ١.
    }

    إذا (فشل == ٠) {
        اطبع "PASS".
        إرجع ٠.
    }

    اطبع "FAIL".
    إرجع ١.
}

