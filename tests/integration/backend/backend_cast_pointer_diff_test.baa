صحيح الرئيسية() {
    صحيح قيمة = ١٠.
    صحيح* بداية = &قيمة.
    صحيح* نهاية = بداية + ٣.

    صحيح فرق = نهاية - بداية.
    إذا (فرق != ٣) { إرجع ١. }

    حرف ح = كـ<حرف>(٦٥).
    صحيح قيمة_ح = كـ<صحيح>(ح).
    إذا (قيمة_ح != ٦٥) { إرجع ٢. }

    ط٨* بايتات = كـ<ط٨*>(بداية).
    صحيح* نفس_المؤشر = كـ<صحيح*>(بايتات).
    إذا (نفس_المؤشر != بداية) { إرجع ٣. }

    ط٦٤ عنوان = كـ<ط٦٤>(بداية).
    صحيح* من_عنوان = كـ<صحيح*>(عنوان).
    إذا (من_عنوان != بداية) { إرجع ٤. }

    عشري ف = كـ<عشري>(٧).
    صحيح ص = كـ<صحيح>(ف).
    إذا (ص != ٧) { إرجع ٥. }

    إرجع ٠.
}
