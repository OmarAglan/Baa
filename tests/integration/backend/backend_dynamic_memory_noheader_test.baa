صحيح الرئيسية() {
    صحيح* م = حجز_ذاكرة(٢ * حجم(صحيح)).
    إذا (م == عدم) { إرجع ١. }

    تعيين_ذاكرة(م، ٠، ٢ * حجم(صحيح)).
    *(م + ٠) = ١٠.
    *(م + ١) = ٢٠.

    صحيح* ق = حجز_ذاكرة(٢ * حجم(صحيح)).
    إذا (ق == عدم) {
        تحرير_ذاكرة(م).
        إرجع ٢.
    }

    نسخ_ذاكرة(ق، م، ٢ * حجم(صحيح)).

    إذا (*(ق + ٠) != ١٠) {
        تحرير_ذاكرة(م).
        تحرير_ذاكرة(ق).
        إرجع ٣.
    }
    إذا (*(ق + ١) != ٢٠) {
        تحرير_ذاكرة(م).
        تحرير_ذاكرة(ق).
        إرجع ٤.
    }

    تحرير_ذاكرة(م).
    تحرير_ذاكرة(ق).
    إرجع ٠.
}
