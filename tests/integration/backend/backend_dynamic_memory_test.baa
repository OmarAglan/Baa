#تضمين "stdlib/baalib.baahd"

صحيح فشل = ٠.

عدم تحقق(منطقي شرط، نص رسالة) {
    إذا (!شرط) {
        اطبع "فشل:".
        اطبع رسالة.
        فشل = فشل + ١.
    }
}

صحيح الرئيسية() {
    صحيح عدد = ٨.
    صحيح بايتات = عدد * حجم(صحيح).

    صحيح* م = حجز_ذاكرة(بايتات).
    تحقق(م != عدم، "حجز_ذاكرة: مؤشر غير فارغ").
    إذا (م == عدم) { إرجع ١. }

    تعيين_ذاكرة(م، ٠، بايتات).
    لكل (صحيح س = ٠؛ س < عدد؛ س = س + ١) {
        تحقق(*(م + س) == ٠، "تعيين_ذاكرة: عنصر صفر").
    }

    لكل (صحيح س = ٠؛ س < عدد؛ س = س + ١) {
        *(م + س) = (س + ١) * ١٠.
    }

    صحيح* ق = حجز_ذاكرة(بايتات).
    تحقق(ق != عدم، "حجز_ذاكرة: q غير فارغ").
    إذا (ق == عدم) {
        تحرير_ذاكرة(م).
        إرجع ٢.
    }

    تعيين_ذاكرة(ق، ٠، بايتات).
    صحيح* ناتج = نسخ_ذاكرة(ق، م، بايتات).
    تحقق(ناتج == ق، "نسخ_ذاكرة: يعيد الوجهة").

    لكل (صحيح س = ٠؛ س < عدد؛ س = س + ١) {
        تحقق(*(ق + س) == *(م + س)، "نسخ_ذاكرة: تطابق").
    }

    صحيح عدد2 = ١٦.
    صحيح بايتات2 = عدد2 * حجم(صحيح).
    صحيح* مؤقت = إعادة_حجز(م، بايتات2).
    تحقق(مؤقت != عدم، "إعادة_حجز: نجاح").
    إذا (مؤقت == عدم) {
        تحرير_ذاكرة(ق).
        تحرير_ذاكرة(م).
        إرجع ٣.
    }
    م = مؤقت.

    لكل (صحيح س = عدد؛ س < عدد2؛ س = س + ١) {
        *(م + س) = س.
    }

    لكل (صحيح س = ٠؛ س < عدد؛ س = س + ١) {
        تحقق(*(م + س) == (س + ١) * ١٠، "إعادة_حجز: الحفاظ على البيانات").
    }

    تحرير_ذاكرة(عدم).
    تحرير_ذاكرة(م).
    تحرير_ذاكرة(ق).

    إذا (فشل == ٠) {
        اطبع "PASS".
        إرجع ٠.
    }
    اطبع "FAIL".
    إرجع ١.
}
