// RUN: runtime

#تضمين "stdlib/baalib.baahd"

صحيح فشل = ٠.

عدم تحقق(منطقي شرط، نص رسالة) {
    إذا (!شرط) {
        اطبع "فشل:".
        اطبع رسالة.
        فشل = فشل + ١.
    }
}

صحيح الرئيسية() {
    تأكد(صواب، "تأكد_سليم").

    تحقق(كود_نجاح == ٠، "كود_نجاح == ٠").
    تحقق(كود_فشل == ١، "كود_فشل == ١").
    تحقق(كود_وسيط_غير_صحيح == ٢، "كود_وسيط_غير_صحيح == ٢").

    ضبط_كود_خطأ_النظام(٢).
    صحيح ك = كود_خطأ_النظام().
    تحقق(ك == ٢، "ضبط/قراءة errno").

    نص وصف = نص_كود_خطأ(ك).
    تحقق(وصف != عدم، "نص_كود_خطأ يعيد نصاً").
    إذا (وصف != عدم) {
        تحقق(طول_نص(وصف) > ٠، "نص كود الخطأ غير فارغ").
        حرر_نص(وصف).
    }

    إذا (خطأ) {
        توقف_فوري("هذا_الفرع_غير_منفذ").
    }

    إذا (فشل == ٠) {
        اطبع "PASS".
        إرجع ٠.
    }

    اطبع "FAIL".
    إرجع ١.
}
