صحيح الرئيسية() {
    نص اسم = ".baa_test_file_io_noheader_tmp.txt".

    عدم* ف = فتح_ملف(اسم, "كتابة").
    إذا (ف == عدم) { إرجع ١. }

    إذا (اكتب_سطر(ف, "ok") != ٠) {
        اغلق_ملف(ف).
        إرجع ٢.
    }
    اغلق_ملف(ف).

    ف = فتح_ملف(اسم, "قراءة").
    إذا (ف == عدم) { إرجع ٣. }

    نص س = اقرأ_سطر(ف).
    إذا (س == عدم) {
        اغلق_ملف(ف).
        إرجع ٤.
    }
    إذا (قارن_نص(س, "ok") != ٠) {
        حرر_نص(س).
        اغلق_ملف(ف).
        إرجع ٥.
    }
    حرر_نص(س).
    اغلق_ملف(ف).
    إرجع ٠.
}
