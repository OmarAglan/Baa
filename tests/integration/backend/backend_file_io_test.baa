#تضمين "stdlib/baalib.baahd"

صحيح فشل = ٠.

عدم تحقق(منطقي شرط، نص رسالة) {
    إذا (!شرط) {
        اطبع "فشل:".
        اطبع رسالة.
        فشل = فشل + ١.
    }
}

صحيح الرئيسية() {
    نص اسم = ".baa_test_file_io_tmp.txt".

    // كتابة + fwrite + سطر فارغ
    عدم* ف = فتح_ملف(اسم, "كتابة").
    تحقق(ف != عدم, "فتح_ملف/كتابة").
    إذا (ف == عدم) { إرجع ١. }

    صحيح ر = اكتب_سطر(ف, "hello").
    تحقق(ر == ٠, "اكتب_سطر: hello").

    ص٨ بايتات[٣] = { 88, 89, 90 }. // XYZ
    صحيح مكتوب = اكتب_ملف(ف, &بايتات[٠], ٣).
    تحقق(مكتوب == ٣, "اكتب_ملف: ٣").

    ر = اكتب_سطر(ف, "").
    تحقق(ر == ٠, "اكتب_سطر: سطر فارغ").

    صحيح غ = اغلق_ملف(ف).
    تحقق(غ == ٠, "اغلق_ملف").

    // إضافة
    ف = فتح_ملف(اسم, "إضافة").
    تحقق(ف != عدم, "فتح_ملف/إضافة").
    إذا (ف == عدم) { إرجع ٢. }
    ر = اكتب_سطر(ف, "world").
    تحقق(ر == ٠, "اكتب_سطر: world").
    اغلق_ملف(ف).

    // قراءة
    ف = فتح_ملف(اسم, "قراءة").
    تحقق(ف != عدم, "فتح_ملف/قراءة").
    إذا (ف == عدم) { إرجع ٣. }

    صحيح م٠ = موقع_ملف(ف).
    تحقق(م٠ == ٠, "موقع_ملف: بداية").

    نص س١ = اقرأ_سطر(ف).
    تحقق(س١ != عدم, "اقرأ_سطر: ١").
    إذا (س١ != عدم) {
        تحقق(قارن_نص(س١, "hello") == ٠, "اقرأ_سطر: hello").
        حرر_نص(س١).
    }

    ص٨ خرج[٣] = { 0, 0, 0 }.
    صحيح مقروء = اقرأ_ملف(ف, &خرج[٠], ٣).
    تحقق(مقروء == ٣, "اقرأ_ملف: ٣").
    تحقق(خرج[٠] == 88, "خرج[٠]").
    تحقق(خرج[١] == 89, "خرج[١]").
    تحقق(خرج[٢] == 90, "خرج[٢]").

    نص س٢ = اقرأ_سطر(ف).
    تحقق(س٢ != عدم, "اقرأ_سطر: سطر فارغ").
    إذا (س٢ != عدم) {
        تحقق(قارن_نص(س٢, "") == ٠, "سطر فارغ").
        حرر_نص(س٢).
    }

    نص س٣ = اقرأ_سطر(ف).
    تحقق(س٣ != عدم, "اقرأ_سطر: world").
    إذا (س٣ != عدم) {
        تحقق(قارن_نص(س٣, "world") == ٠, "world").
        حرر_نص(س٣).
    }

    نص س٤ = اقرأ_سطر(ف).
    تحقق(س٤ == عدم, "EOF: اقرأ_سطر يعيد عدم").

    منطقي انتهى = نهاية_ملف(ف).
    تحقق(انتهى == صواب, "نهاية_ملف بعد EOF").

    اغلق_ملف(ف).

    // اختبار seek + read_char
    ف = فتح_ملف(اسم, "قراءة").
    إذا (ف == عدم) { إرجع ٤. }
    صحيح س = اذهب_لموقع(ف, ٠).
    تحقق(س == ٠, "اذهب_لموقع: ٠").
    حرف ح = اقرأ_حرف(ف).
    تحقق(ح == 'h', "اقرأ_حرف: h").
    اغلق_ملف(ف).

    // اختبار اكتب_حرف/اقرأ_حرف مع UTF-8
    نص اسم٢ = ".baa_test_file_char_tmp.txt".
    ف = فتح_ملف(اسم٢, "كتابة").
    إذا (ف == عدم) { إرجع ٥. }
    اكتب_حرف(ف, 'A').
    اكتب_حرف(ف, 'أ').
    اكتب_حرف(ف, 'B').
    اغلق_ملف(ف).

    ف = فتح_ملف(اسم٢, "قراءة").
    إذا (ف == عدم) { إرجع ٦. }
    حرف ح٠ = اقرأ_حرف(ف).
    حرف ح١ = اقرأ_حرف(ف).
    حرف ح٢ = اقرأ_حرف(ف).
    حرف ح٣ = اقرأ_حرف(ف).
    تحقق(ح٠ == 'A', "ح٠").
    تحقق(ح١ == 'أ', "ح١").
    تحقق(ح٢ == 'B', "ح٢").
    تحقق(ح٣ == ٠, "EOF: اقرأ_حرف يعيد ٠").
    اغلق_ملف(ف).

    إذا (فشل == ٠) {
        اطبع "PASS".
        إرجع ٠.
    }
    اطبع "FAIL".
    إرجع ١.
}
