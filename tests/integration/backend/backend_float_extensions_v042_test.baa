#تضمين "stdlib/baalib.baahd"

صحيح فشل = ٠.

عدم تحقق(منطقي شرط، نص رسالة) {
    إذا (!شرط) {
        اطبع "فشل:".
        اطبع رسالة.
        فشل = فشل + ١.
    }
}

منطقي قريب(عشري قيمة، عشري هدف، عشري هامش) {
    عشري فرق = قيمة - هدف.
    إذا (فرق < ٠.٠) {
        فرق = -فرق.
    }
    إرجع فرق <= هامش.
}

منطقي يحتوي_أسي(نص س) {
    صحيح م = ٠.
    طالما (س[م] != ٠) {
        إذا (س[م] == 'e' || س[م] == 'E') {
            إرجع صواب.
        }
        م = م + ١.
    }
    إرجع خطأ.
}

صحيح الرئيسية() {
    عشري٣٢ زاوية = ٠.٠.

    تحقق(قريب(جيب(زاوية)، ٠.٠، 0.000001)، "جيب(٠) ≈ ٠").
    تحقق(قريب(جيب_تمام(زاوية)، ١.٠، 0.000001)، "جيب_تمام(٠) ≈ ١").
    تحقق(قريب(ظل(زاوية)، ٠.٠، 0.000001)، "ظل(٠) ≈ ٠").

    عشري٣٢ أ = ١.٥.
    عشري٣٢ ب = ٢.٥.
    عشري٣٢ ج = أ + ب.
    تحقق(قريب(ج، ٤.٠، 0.000001)، "عمليات عشري٣٢").

    نص علمي = نسق("x=%.3أ", 1234.5).
    تحقق(علمي != عدم، "نسق(%أ) يعيد نصاً").
    إذا (علمي != عدم) {
        تحقق(طول_نص(علمي) > ٠، "ناتج %أ غير فارغ").
        تحقق(يحتوي_أسي(علمي)، "ناتج %أ بصيغة علمية").
        حرر_نص(علمي).
    }

    إذا (فشل == ٠) {
        اطبع "PASS".
        إرجع ٠.
    }

    اطبع "FAIL".
    إرجع ١.
}
