// RUN: runtime

#تضمين "stdlib/baalib.baahd"

صحيح الرئيسية() {
    نص ناتج = نسق("i=%ص u=%ط x=%س pct=%% s=%ن c=%ح f=%.2ع",
                  -4,
                  كـ<ط٦٤>(4000000001),
                  كـ<ط٦٤>(42),
                  "مرحبا",
                  'a',
                  3.5).

    إذا (قارن_نص(ناتج, "i=-4 u=4000000001 x=2a pct=% s=مرحبا c=a f=3.50") != 0) {
        // للتشخيص عند الفشل
        اطبع ناتج.
        حرر_نص(ناتج).
        إرجع 1.
    }

    حرر_نص(ناتج).

    // Smoke test: اطبع_منسق يخفض إلى printf.
    اطبع_منسق("ok %ص %ن\س", 7, "done").

    إرجع 0.
}
