// ============================================================================
// اختبار تظليل (Shadowing) مؤشر الدالة على اسم دالة — v0.3.10.6
// ============================================================================

صحيح جمع(صحيح أ, صحيح ب) {
    إرجع أ + ب.
}

صحيح ضرب(صحيح أ, صحيح ب) {
    إرجع أ * ب.
}

صحيح الرئيسية() {
    // متغير يحمل نفس اسم الدالة "جمع" ويجب أن يطغى عليها داخل النطاق.
    دالة(صحيح, صحيح) -> صحيح جمع = ضرب.

    صحيح ن = جمع(٢, ٣). // يجب أن ينادي المتغير (=> ضرب) وليس الدالة المباشرة جمع.
    إذا (ن != ٦) { إرجع ١. }

    إرجع ٠.
}

