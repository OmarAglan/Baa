// ============================================================================
// اختبار مؤشرات الدوال (Function Pointers) — v0.3.10.6
// ============================================================================

صحيح اجمع(صحيح أ, صحيح ب) {
    إرجع أ + ب.
}

صحيح طبق(دالة(صحيح, صحيح) -> صحيح ف, صحيح أ, صحيح ب) {
    إرجع ف(أ, ب).
}

صحيح الرئيسية() {
    دالة(صحيح, صحيح) -> صحيح ف = اجمع.

    صحيح ن = ف(٢, ٣).
    إذا (ن != ٥) { إرجع ١. }

    صحيح م = طبق(اجمع, ١٠, ٢٠).
    إذا (م != ٣٠) { إرجع ٢. }

    إذا (ف == عدم) { إرجع ٣. }
    ف = عدم.
    إذا (ف != عدم) { إرجع ٤. }

    إرجع ٠.
}

