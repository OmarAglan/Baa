// مصفوفة عامة مع تهيئة جزئية
صحيح قائمة[٥] = {١، ٢، ٣}.

صحيح الرئيسية() {
    صحيح مجموع = ٠.
    مجموع = مجموع + قائمة[٠].
    مجموع = مجموع + قائمة[١].
    مجموع = مجموع + قائمة[٢].
    مجموع = مجموع + قائمة[٣].
    مجموع = مجموع + قائمة[٤].

    // ١ + ٢ + ٣ + ٠ + ٠ = ٦
    إذا (مجموع != ٦) { إرجع ١. }

    إرجع ٠.
}
