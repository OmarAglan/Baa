// RUN: expect-pass runtime

#تعريف عدد_محلي ٣

#تضمين "tests/fixtures/lexer_production/lexer_signoff_header.baahd"
#تضمين "stdlib/baalib.baahd"

#إذا_عرف عدد_محلي
صحيح فرع_عرف() {
    إرجع عدد_محلي.
}
#وإلا
صحيح فرع_عرف() {
    إرجع ٠.
}
#نهاية

#إذا_لم_يعرف غير_موجود
صحيح فرع_لم_يعرف() {
    إرجع ٤.
}
#وإلا
صحيح فرع_لم_يعرف() {
    إرجع ٠.
}
#نهاية

#إذا_لم_يعرف ثابت_ترويسة
صحيح فرع_ترويسة() {
    إرجع ٠.
}
#وإلا
صحيح فرع_ترويسة() {
    إرجع ثابت_ترويسة.
}
#نهاية

صحيح جمع_بعربية(صحيح أ، صحيح ب) {
    إرجع أ + ب.
}

صحيح الرئيسية() {
    صحيح عدد = ١٢٣.
    نص رسالة = "مرحبا".
    حرف ألف = 'أ'.
    حرف اقتباس = '\''.
    ط٨* خام_نص = خام"abc-أ".

    إذا (عدد != ١٢٣) { إرجع ١. }
    إذا (قارن_نص(رسالة، "مرحبا") != ٠) { إرجع ٢. }
    إذا (ألف != 'أ') { إرجع ٣. }
    إذا (اقتباس != '\'') { إرجع ٤. }
    إذا (طول_خام(خام_نص) != ٦) { إرجع ٥. }
    إذا (قارن_خام(خام_نص، خام"abc-أ") != ٠) { إرجع ٦. }
    إذا (فرع_عرف() != ٣) { إرجع ٧. }
    إذا (فرع_لم_يعرف() != ٤) { إرجع ٨. }
    إذا (فرع_ترويسة() != ٧) { إرجع ٩. }
    إذا (قيمة_من_ترويسة() != ٧) { إرجع ١٠. }
    إذا (جمع_بعربية(٢، ٣) != ٥) { إرجع ١١. }

    إرجع ٠.
}
