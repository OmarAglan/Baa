// RUN: expect-pass runtime

صحيح قيمة_عامة_بطول_يتجاوز_الحد_القديم = ٤.

نوع معرف_عددي_بطول_يتجاوز_الحد_القديم = صحيح.

معرف_عددي_بطول_يتجاوز_الحد_القديم احسب_اسما_محليا_طويلا(معرف_عددي_بطول_يتجاوز_الحد_القديم وسيط_بطول_يتجاوز_الحد_القديم) {
    معرف_عددي_بطول_يتجاوز_الحد_القديم قيمة_محلية_بطول_يتجاوز_الحد_القديم = وسيط_بطول_يتجاوز_الحد_القديم + قيمة_عامة_بطول_يتجاوز_الحد_القديم.
    إرجع قيمة_محلية_بطول_يتجاوز_الحد_القديم.
}

صحيح الرئيسية() {
    إذا (احسب_اسما_محليا_طويلا(٣) != ٧) {
        إرجع ١.
    }

    إرجع ٠.
}
