// اختبار عمليات المستوى المنخفض (v0.3.6)

صحيح عد = ٠.

صحيح تحقق(صحيح فعلي, صحيح متوقع) {
    عد = عد + ١.
    إذا (فعلي != متوقع) {
        اطبع "فشل تحقق:". 
        اطبع عد.
        اطبع "فعلي:".
        اطبع فعلي.
        اطبع "متوقع:".
        اطبع متوقع.
        إرجع ١.
    }
    إرجع ٠.
}

عدم دالة_عدم_مع_إرجاع() {
    إرجع.
}

عدم دالة_عدم_بدون_إرجاع() {
    اطبع "ok".
}

صحيح اختبار_عمليات_بتية() {
    صحيح خ = ٠.
    خ = خ + تحقق(٥ & ٣, ١).
    خ = خ + تحقق(٥ | ٣, ٧).
    خ = خ + تحقق(٥ ^ ٣, ٦).
    خ = خ + تحقق(~٥, -٦).
    خ = خ + تحقق(١ << ٤, ١٦).
    خ = خ + تحقق(١٦ >> ٢, ٤).
    خ = خ + تحقق(-٨ >> ١, -٤).
    إرجع خ.
}

صحيح اختبار_إزاحة_غير_موقعة() {
    صحيح خ = ٠.
    ط٣٢ ق = ٤٢٩٤٩٦٧٢٨٨.
    ط٣٢ ن = ق >> ١.
    خ = خ + تحقق(ن, ٢١٤٧٤٨٣٦٤٤).
    إرجع خ.
}

صحيح اختبار_حجم() {
    صحيح خ = ٠.
    صحيح قائمة[٤] = {١، ٢، ٣، ٤}.

    خ = خ + تحقق(حجم(صحيح), ٨).
    خ = خ + تحقق(حجم(ص٣٢), ٤).
    خ = خ + تحقق(حجم(ط٨), ١).
    خ = خ + تحقق(حجم(قائمة), ٣٢).
    خ = خ + تحقق(حجم(قائمة[٠]), ٨).

    إرجع خ.
}

صحيح الرئيسية() {
    صحيح خ = ٠.

    دالة_عدم_مع_إرجاع().
    دالة_عدم_بدون_إرجاع().

    خ = خ + اختبار_عمليات_بتية().
    خ = خ + اختبار_إزاحة_غير_موقعة().
    خ = خ + اختبار_حجم().

    إذا (خ == ٠) {
        اطبع "PASS".
    } وإلا {
        اطبع "FAIL".
    }

    إرجع خ.
}
