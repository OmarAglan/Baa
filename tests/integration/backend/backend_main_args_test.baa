// RUN: runtime
// ARGS: alpha beta

صحيح الرئيسية(صحيح عدد، نص[] معاملات) {
    إذا (عدد != ٣) {
        إرجع ١.
    }

    إذا (قارن_نص(معاملات[١], "alpha") != ٠) {
        إرجع ٢.
    }

    إذا (قارن_نص(معاملات[٢], "beta") != ٠) {
        إرجع ٣.
    }

    حرف ح = معاملات[١][٠].
    إذا (ح != 'a') {
        إرجع ٤.
    }

    إرجع ٠.
}

