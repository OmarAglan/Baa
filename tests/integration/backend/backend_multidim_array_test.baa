// اختبار دعم المصفوفات متعددة الأبعاد (v0.3.9)

هيكل نقطة {
    صحيح س.
    صحيح ص.
}

صحيح عالمي_م[٢][٣] = {{١، ٢، ٣}, {٤، ٥}}.
صحيح عالمي_مسطح[٢][٣] = {١، ٢، ٣، ٤، ٥، ٦}.
نص أسماء[٢] = {"علي"، "عمر"}.

صحيح عداد_ثابت_مصفوفة() {
    ساكن صحيح م[٢][٢] = {{١، ٠}, {٠، ٠}}.
    م[١][١] = م[١][١] + ١.
    إرجع م[٠][٠] + م[١][١].
}

صحيح الرئيسية() {
    // 1) فهرسة/تهيئة متعددة الأبعاد (global + nested)
    إذا (عالمي_م[٠][٠] != ١) { إرجع ١. }
    إذا (عالمي_م[٠][٢] != ٣) { إرجع ٢. }
    إذا (عالمي_م[١][٠] != ٤) { إرجع ٣. }
    إذا (عالمي_م[١][١] != ٥) { إرجع ٤. }
    إذا (عالمي_م[١][٢] != ٠) { إرجع ٥. }

    // 2) تهيئة مسطحة row-major
    إذا (عالمي_مسطح[١][٠] != ٤) { إرجع ٦. }
    إذا (عالمي_مسطح[١][٢] != ٦) { إرجع ٧. }

    // 3) مصفوفة محلية متعددة الأبعاد
    صحيح محلي[٢][٣] = {{١٠، ٢٠، ٣٠}, {٤٠، ٥٠، ٦٠}}.
    محلي[١][١] = محلي[١][١] + ٥.
    إذا (محلي[١][١] != ٥٥) { إرجع ٨. }

    // 4) أنواع صحيحة بأحجام مختلفة
    ص٨ صغار[٢][٢] = {١، ٢، ٣، ٤}.
    إذا (صغار[١][٠] != ٣) { إرجع ٩. }

    // 5) مصفوفة عشري
    عشري ف[٢][٢] = {{١.٥، ٢.٥}, {٣.٥، ٤.٥}}.
    إذا (ف[١][٠] != ٣.٥) { إرجع ١٠. }

    // 6) مصفوفة نص + فهرسة نص
    إذا (أسماء[٠][٠] != 'ع') { إرجع ١١. }
    إذا (أسماء[١][١] != 'م') { إرجع ١٢. }

    // 7) مصفوفة هياكل + وصول عضو
    هيكل نقطة نقاط[٢].
    نقاط[٠]:س = ٧.
    نقاط[٠]:ص = ٩.
    نقاط[١]:س = ١١.
    إذا (نقاط[٠]:س != ٧) { إرجع ١٣. }
    إذا (نقاط[٠]:ص != ٩) { إرجع ١٤. }
    إذا (نقاط[١]:س != ١١) { إرجع ١٥. }

    // 8) مصفوفة ثابتة محلية ساكنة
    إذا (عداد_ثابت_مصفوفة() != ٢) { إرجع ١٦. }
    إذا (عداد_ثابت_مصفوفة() != ٣) { إرجع ١٧. }

    إرجع ٠.
}
