صحيح الرئيسية() {
    صحيح قيمة = ١٠.
    صحيح* مؤشر = &قيمة.

    إذا (*مؤشر != ١٠) { إرجع ١. }

    *مؤشر = ٢٥.
    إذا (قيمة != ٢٥) { إرجع ٢. }

    صحيح* مؤشر2 = مؤشر + ١.
    صحيح* مؤشر3 = مؤشر2 - ١.
    إذا (مؤشر3 != مؤشر) { إرجع ٣. }

    صحيح* فارغ = عدم.
    إذا (فارغ != عدم) { إرجع ٤. }

    إرجع ٠.
}
