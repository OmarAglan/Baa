#تضمين "stdlib/baalib.baahd"

صحيح الرئيسية() {
    ط٨* أ = خام"abc".

    إذا (طول_خام(أ) != ٣) {
        إرجع ١.
    }

    إذا (*(أ + ٠) != ٩٧) {
        إرجع ٢.
    }

    إذا (*(أ + ١) != ٩٨) {
        إرجع ٣.
    }

    إذا (قارن_خام(أ, خام"abc") != ٠) {
        إرجع ٤.
    }

    إذا (قارن_خام(خام"abc", خام"abd") >= ٠) {
        إرجع ٥.
    }

    إذا (قارن_خام(خام"abd", خام"abc") <= ٠) {
        إرجع ٦.
    }

    إذا (!قارن_خام_بطول(خام"keyword:", ٧, خام"keyword")) {
        إرجع ٧.
    }

    إذا (قارن_خام_بطول(خام"key", ٣, خام"keyword")) {
        إرجع ٨.
    }

    إذا (طول_خام(خام"صحيح") != ٨) {
        إرجع ٩.
    }

    إرجع ٠.
}
