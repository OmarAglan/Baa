// RUN: runtime
// STDIN: hello
// STDIN: world

#تضمين "stdlib/baalib.baahd"

صحيح الرئيسية() {
    نص أ = اقرأ_سطر().
    إذا (أ == عدم) { إرجع 1. }
    إذا (قارن_نص(أ, "hello") != 0) { حرر_نص(أ). إرجع 2. }
    حرر_نص(أ).

    نص ب = اقرأ_سطر().
    إذا (ب == عدم) { إرجع 3. }
    إذا (قارن_نص(ب, "world") != 0) { حرر_نص(ب). إرجع 4. }
    حرر_نص(ب).

    نص ج = اقرأ_سطر().
    إذا (ج != عدم) { حرر_نص(ج). إرجع 5. }

    إرجع 0.
}

