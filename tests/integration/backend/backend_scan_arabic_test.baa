// RUN: runtime
// STDIN: 42 3.5 hello

#تضمين "stdlib/baalib.baahd"

صحيح الرئيسية() {
    صحيح أ = 0.
    عشري ب = 0.0.
    نص س = عدم.

    صحيح عدد = اقرأ_منسق("%ص %ع %10ن", &أ, &ب, &س).
    إذا (عدد != 3) {
        إذا (س != عدم) { حرر_نص(س). }
        إرجع 1.
    }

    إذا (أ != 42) {
        حرر_نص(س).
        إرجع 2.
    }

    إذا (ب < 3.49 || ب > 3.51) {
        حرر_نص(س).
        إرجع 3.
    }

    إذا (قارن_نص(س, "hello") != 0) {
        حرر_نص(س).
        إرجع 4.
    }

    حرر_نص(س).
    إرجع 0.
}

