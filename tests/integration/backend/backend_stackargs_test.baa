// ============================================================================
// اختبار معاملات المكدس في النداءات — v0.3.2.8.5
// ============================================================================

صحيح جمع٨(صحيح ا, صحيح ب, صحيح ج, صحيح د, صحيح هـ, صحيح و, صحيح ز, صحيح ح) {
    إرجع ا + ب + ج + د + هـ + و + ز + ح.
}

صحيح الرئيسية() {
    // ٨ معاملات: على Windows سيكون ٤ في السجلات و ٤ على المكدس.
    // على SysV سيكون ٦ في السجلات و ٢ على المكدس.
    صحيح ر = جمع٨(1, 2, 3, 4, 5, 6, 7, 8).

    إذا (ر != 36) {
        اطبع "FAIL".
        إرجع 1.
    }

    اطبع "PASS".
    إرجع 0.
}
