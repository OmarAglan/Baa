// ============================================================================
// اختبار التخزين الساكن (ساكن) - v0.3.7.5
// ============================================================================
// الهدف:
// - التحقق من بقاء المتغيرات المحلية الساكنة بين النداءات.
// - التحقق من التصفير الافتراضي للمتغير/المصفوفة الساكنة دون تهيئة.
// - التحقق من قبول ترتيب الواصفات: "ثابت ساكن" و"ساكن ثابت".
// - التحقق من دعم المتغيرات/المصفوفات العامة مع "ساكن".
// ============================================================================

ثابت ساكن صحيح ثابت_عام_١ = ٧.
ساكن ثابت صحيح ثابت_عام_٢ = ٨.
ساكن صحيح مخزن_عام[٣] = {٣}.

صحيح عدد_الاختبارات = ٠.

صحيح تحقق(صحيح فعلي, صحيح متوقع) {
    عدد_الاختبارات = عدد_الاختبارات + ١.
    إذا (فعلي != متوقع) {
        إرجع ١.
    }
    إرجع ٠.
}

صحيح عداد_ساكن() {
    ساكن صحيح ع.
    ع = ع + ١.
    إرجع ع.
}

صحيح مجموع_مصفوفة_ساكنة() {
    ساكن صحيح م[٤] = {١، ٢}.
    م[٢] = م[٢] + ٥.
    م[٣] = م[٣] + ٧.
    إرجع م[٠] + م[١] + م[٢] + م[٣].
}

صحيح افتراضي_ثابت_ساكن() {
    ساكن ثابت صحيح ق.
    إرجع ق.
}

صحيح جمع_واصفات_ساكنة() {
    ثابت ساكن صحيح أ = ٤.
    ساكن ثابت صحيح ب = ٦.
    إرجع أ + ب.
}

صحيح تحديث_مخزن_عام() {
    مخزن_عام[١] = مخزن_عام[١] + ١.
    إرجع مخزن_عام[٠] + مخزن_عام[١] + مخزن_عام[٢].
}

صحيح الرئيسية() {
    صحيح أخطاء = ٠.

    أخطاء = أخطاء + تحقق(ثابت_عام_١, ٧).
    أخطاء = أخطاء + تحقق(ثابت_عام_٢, ٨).

    أخطاء = أخطاء + تحقق(عداد_ساكن(), ١).
    أخطاء = أخطاء + تحقق(عداد_ساكن(), ٢).
    أخطاء = أخطاء + تحقق(عداد_ساكن(), ٣).

    أخطاء = أخطاء + تحقق(مجموع_مصفوفة_ساكنة(), ١٥).
    أخطاء = أخطاء + تحقق(مجموع_مصفوفة_ساكنة(), ٢٧).

    أخطاء = أخطاء + تحقق(افتراضي_ثابت_ساكن(), ٠).
    أخطاء = أخطاء + تحقق(جمع_واصفات_ساكنة(), ١٠).

    أخطاء = أخطاء + تحقق(تحديث_مخزن_عام(), ٤).
    أخطاء = أخطاء + تحقق(تحديث_مخزن_عام(), ٥).

    // 11 تحقق
    أخطاء = أخطاء + تحقق(عدد_الاختبارات, ١١).
    إرجع أخطاء.
}
