#تضمين "stdlib/baalib.baahd"

صحيح فشل = ٠.

عدم تحقق(منطقي شرط، نص رسالة) {
    إذا (!شرط) {
        اطبع "فشل:".
        اطبع رسالة.
        فشل = فشل + ١.
    }
}

صحيح الرئيسية() {
    عشري ج = جذر_تربيعي(٩.٠).
    تحقق(ج > ٢.٩ && ج < ٣.١، "جذر_تربيعي(٩) ≈ ٣").

    عشري ق = أس(٢.٠، ٣.٠).
    تحقق(ق > ٧.٩ && ق < ٨.١، "أس(٢،٣) ≈ ٨").

    تحقق(مطلق(-١٢٣) == ١٢٣، "مطلق(-١٢٣) == ١٢٣").

    صحيح ع = عشوائي().
    تحقق(ع >= ٠، "عشوائي() >= ٠").

    نص مسار = متغير_بيئة("PATH").
    تحقق(مسار != عدم، "متغير_بيئة(PATH) != عدم").
    إذا (مسار != عدم) {
        حرر_نص(مسار).
    }

    صحيح رمز = نفذ_أمر("echo BAA_STDLIB_041_TEST").
    تحقق(رمز >= ٠، "نفذ_أمر(...) نجح").

    صحيح الآن = وقت_حالي().
    تحقق(الآن > ٠، "وقت_حالي() > ٠").

    نص ختم = وقت_كنص(الآن).
    تحقق(ختم != عدم، "وقت_كنص(...) != عدم").
    إذا (ختم != عدم) {
        حرر_نص(ختم).
    }

    إذا (فشل == ٠) {
        اطبع "PASS".
        إرجع ٠.
    }

    اطبع "FAIL".
    إرجع ١.
}
