#تضمين "stdlib/baalib.baahd"

صحيح فشل = ٠.

عدم تحقق(منطقي شرط، نص رسالة) {
    إذا (!شرط) {
        اطبع "فشل:".
        اطبع رسالة.
        فشل = فشل + ١.
    }
}

صحيح الرئيسية() {
    تحقق(طول_نص("مرحبا") == ٥، "طول_نص: مرحبا = ٥").
    تحقق(طول_نص("باء") == ٣، "طول_نص: باء = ٣").

    تحقق(قارن_نص("أ"، "أ") == ٠، "قارن_نص: تساوي").
    تحقق(قارن_نص("أ"، "ب") < ٠، "قارن_نص: أ < ب").
    تحقق(قارن_نص("ب"، "أ") > ٠، "قارن_نص: ب > أ").

    نص م = دمج_نص("مرح"، "با").
    تحقق(قارن_نص(م، "مرحبا") == ٠، "دمج_نص: مرح + با").

    نص ن = نسخ_نص(م).
    تحقق(قارن_نص(ن، م) == ٠، "نسخ_نص: النسخة تساوي الأصل").

    حرر_نص(ن).
    حرر_نص(م).

    إذا (فشل == ٠) {
        اطبع "PASS".
        إرجع ٠.
    }
    اطبع "FAIL".
    إرجع ١.
}

