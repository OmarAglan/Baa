// RUN: runtime
// اختبار الوصول إلى أعضاء الهيكل عبر مؤشر، وهو مطلوب لتبسيط حالة المحلل اللفظي في باء.

هيكل موضع {
    صحيح سطر.
    صحيح عمود.
}

صحيح الرئيسية() {
    هيكل موضع م.
    م:سطر = ١٠.
    م:عمود = ٢٠.

    هيكل موضع* مؤشر = &م.
    إذا (مؤشر->سطر != ١٠) { إرجع ١. }

    مؤشر->عمود = مؤشر->عمود + ٥.
    إذا (م:عمود != ٢٥) { إرجع ٢. }

    إرجع ٠.
}
