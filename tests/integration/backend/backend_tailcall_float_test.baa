// اختبار تراجع: tailcall مع معاملات عشرية يجب أن يبقى صحيحاً على O2.

عشري مجموع_ذيلي_عشري(صحيح ن, عشري م) {
    إذا (ن == 0) {
        إرجع م.
    }
    إرجع مجموع_ذيلي_عشري(ن - 1, م + ١.٥).
}

صحيح الرئيسية() {
    عشري ر = مجموع_ذيلي_عشري(٤, ٠.٠).
    صحيح ص = ر * ٢.
    إذا (ص != ١٢) {
        إرجع 1.
    }
    إرجع 0.
}
