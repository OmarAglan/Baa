// ============================================================================
// اختبار شامل للخلفية الجديدة (IR-based Backend Comprehensive Test)
// ============================================================================
//
// هذا الملف يختبر جميع ميزات لغة باء المدعومة في الخلفية المبنية على IR.
// كل دالة اختبار بسيطة (قليلة المتغيرات) لتجنب ضغط السجلات.
// الدالة الرئيسية تجمع الأخطاء وتُرجع العدد الكلّي (٠ = نجاح).
//
// التشغيل:
//   build\baa.exe tests\integration\backend\backend_test.baa -o build\backend_test.exe -v
//   build\backend_test.exe
//   echo %ERRORLEVEL%     (يجب أن يكون 0)
// ============================================================================

// ────────────────────────────────────────────────────────────────────────────
// المعالج القبلي (Preprocessor)
// ────────────────────────────────────────────────────────────────────────────

#تضمين "tests/fixtures/backend_test_inc.baahd"

#تعريف ماكرو_تجربة 42

#إذا_عرف ماكرو_تجربة
صحيح ثابت_من_ماكرو() {
    إرجع ماكرو_تجربة.
}
#نهاية

// تأكيد أن وضع التخطي يعمل: هذا السطر يحوي محرفاً غير مدعوم لو تم تحليله.
#الغاء_تعريف ماكرو_تخطي
#إذا_عرف ماكرو_تخطي
x
#نهاية
 
// ────────────────────────────────────────────────────────────────────────────
// المتغيرات العامة (Global Variables)
// ────────────────────────────────────────────────────────────────────────────
صحيح عد = ٠.
صحيح متغير_عام = ٠.

حرف حرف_عام = 'أ'.

نص نص_عام = "أب".

عشري عشري_عام = ٣.١٤.

// ثوابت عامة
ثابت صحيح الحد = ١٠.
ثابت صحيح المعامل = ٣.

// ────────────────────────────────────────────────────────────────────────────
// أنواع مركبة (Enumerations & Structures) — v0.3.4
// ────────────────────────────────────────────────────────────────────────────

تعداد لون {
    أحمر،
    أزرق،
    أسود،
    أبيض،
}

اتحاد قيمة {
    صحيح رقم.
    نص نص_قيمة.
}

هيكل محرك {
    صحيح قوة.
}

هيكل سيارة {
    نص موديل.
    صحيح سنة_الصنع.
    تعداد لون لون_السيارة.
    هيكل محرك محرك_السيارة.
}

// ────────────────────────────────────────────────────────────────────────────
// مصفوفات عامة مع تهيئة (Global Arrays Init) — v0.3.3
// ────────────────────────────────────────────────────────────────────────────

صحيح قائمة_عام[٥] = {١، ٢، ٣}.

// ────────────────────────────────────────────────────────────────────────────
// متغير عام من نوع هيكل (Global Struct)
// ────────────────────────────────────────────────────────────────────────────

هيكل محرك محرك_عام.

// ────────────────────────────────────────────────────────────────────────────
// دالة مساعدة: تحقق (Helper: Assert)
// ────────────────────────────────────────────────────────────────────────────
صحيح تحقق(صحيح فعلي, صحيح متوقع) {
    عد = عد + ١.
    إذا (فعلي != متوقع) {
        اطبع "فشل تحقق:".
        اطبع عد.
        اطبع "فعلي:".
        اطبع فعلي.
        اطبع "متوقع:".
        اطبع متوقع.
        إرجع ١.
    }
    إرجع ٠.
}

// ════════════════════════════════════════════════════════════════════════════
// ٣٢. المعالج القبلي (Preprocessor)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_معالج_قبلي() {
    صحيح خ = ٠.
    خ = خ + تحقق(ثابت_من_ماكرو(), ٤٢).
    خ = خ + تحقق(دالة_مضمنة(), ٩٩).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٣٣. تهيئة المصفوفات (Array Initialization)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_تهيئة_مصفوفة_محلية() {
    صحيح خ = ٠.

    صحيح أ[٥] = {١، ٢}.
    خ = خ + تحقق(أ[٠], ١).
    خ = خ + تحقق(أ[١], ٢).
    خ = خ + تحقق(أ[٢], ٠).
    خ = خ + تحقق(أ[٣], ٠).
    خ = خ + تحقق(أ[٤], ٠).

    صحيح ب[٣] = {}.
    خ = خ + تحقق(ب[٠], ٠).
    خ = خ + تحقق(ب[١], ٠).
    خ = خ + تحقق(ب[٢], ٠).

    إرجع خ.
}

صحيح اختبار_تهيئة_مصفوفة_عامة() {
    صحيح خ = ٠.
    صحيح مجموع = ٠.
    مجموع = مجموع + قائمة_عام[٠].
    مجموع = مجموع + قائمة_عام[١].
    مجموع = مجموع + قائمة_عام[٢].
    مجموع = مجموع + قائمة_عام[٣].
    مجموع = مجموع + قائمة_عام[٤].
    خ = خ + تحقق(مجموع, ٦).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٣٤. التعداد (Enum) + الوصول المؤهل (Enum:Member)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_تعداد() {
    صحيح خ = ٠.
    تعداد لون ل = لون:أحمر.
    صحيح نتيجة = ٠.
    إذا (ل == لون:أحمر) { نتيجة = ١. }
    خ = خ + تحقق(نتيجة, ١).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٣٥. الهياكل (Struct) + الوصول للأعضاء (:) + التعشيش
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_هيكل_محلي() {
    صحيح خ = ٠.
    هيكل سيارة س.

    س:موديل = "تويوتا".
    س:سنة_الصنع = ٢٠٢٤.
    س:لون_السيارة = لون:أحمر.
    س:محرك_السيارة:قوة = ١٥٠.

    خ = خ + تحقق(س:سنة_الصنع, ٢٠٢٤).
    خ = خ + تحقق(س:محرك_السيارة:قوة, ١٥٠).

    صحيح نتيجة = ٠.
    إذا (س:لون_السيارة == لون:أحمر) { نتيجة = ١. }
    خ = خ + تحقق(نتيجة, ١).

    صحيح نتيجة٢ = ٠.
    إذا (١ == ١) { نتيجة٢ = ١. }
    خ = خ + تحقق(نتيجة٢, ١).

    // فقط للتأكد من عدم الانهيار عند قراءة نص
    اطبع س:موديل.

    إرجع خ.
}

صحيح اختبار_هيكل_عام() {
    صحيح خ = ٠.
    محرك_عام:قوة = ٧.
    خ = خ + تحقق(محرك_عام:قوة, ٧).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٣٦. الاتحادات (Union) + الوصول للأعضاء (:)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_اتحاد() {
    صحيح خ = ٠.

    اتحاد قيمة ق.
    ق:رقم = ٤٢.
    خ = خ + تحقق(ق:رقم, ٤٢).

    ق:نص_قيمة = "مرحبا".
    اطبع ق:نص_قيمة.

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ١. الجمع والطرح (Addition & Subtraction)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_جمع_طرح() {
    صحيح خ = ٠.
    خ = خ + تحقق(٣٠ + ١٢, ٤٢).
    خ = خ + تحقق(٣٠ - ١٢, ١٨).
    خ = خ + تحقق(٠ + ٠, ٠).
    خ = خ + تحقق(١٠٠ - ١٠٠, ٠).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٢. الضرب (Multiplication)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_ضرب() {
    صحيح خ = ٠.
    خ = خ + تحقق(٣٠ * ١٢, ٣٦٠).
    خ = خ + تحقق(٠ * ٩٩٩, ٠).
    خ = خ + تحقق(٧ * ١, ٧).
    خ = خ + تحقق(٢ + ٣ * ٤, ١٤).
    خ = خ + تحقق((٢ + ٣) * ٤, ٢٠).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٣. القسمة (Division)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_قسمة() {
    صحيح خ = ٠.
    خ = خ + تحقق(٣٠ / ١٢, ٢).
    خ = خ + تحقق(١٠٠ / ١٠, ١٠).
    خ = خ + تحقق(٧ / ١, ٧).
    خ = خ + تحقق(٣ / ١٠, ٠).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٤. السالب الأحادي (Unary Negation)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_سالب() {
    صحيح خ = ٠.
    صحيح ج = -٥.
    خ = خ + تحقق(ج, -٥).
    خ = خ + تحقق(-ج, ٥).
    خ = خ + تحقق(-٠, ٠).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٥. المقارنات (Comparisons)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_مقارنات() {
    صحيح خ = ٠.
    صحيح أ = ١٠.
    صحيح ب = ٢٠.

    // يساوي
    صحيح ن١ = ٠.
    إذا (أ == ١٠) { ن١ = ١. }
    خ = خ + تحقق(ن١, ١).

    // لا يساوي
    صحيح ن٢ = ٠.
    إذا (أ != ب) { ن٢ = ١. }
    خ = خ + تحقق(ن٢, ١).

    // أكبر
    صحيح ن٣ = ٠.
    إذا (ب > أ) { ن٣ = ١. }
    خ = خ + تحقق(ن٣, ١).

    // أصغر
    صحيح ن٤ = ٠.
    إذا (أ < ب) { ن٤ = ١. }
    خ = خ + تحقق(ن٤, ١).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٦. مقارنات أكبر/أصغر أو يساوي (GE/LE)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_مقارنات٢() {
    صحيح خ = ٠.

    صحيح ن١ = ٠.
    إذا (١٠ <= ١٠) { ن١ = ١. }
    خ = خ + تحقق(ن١, ١).

    صحيح ن٢ = ٠.
    إذا (١٠ >= ١٠) { ن٢ = ١. }
    خ = خ + تحقق(ن٢, ١).

    صحيح ن٣ = ٠.
    إذا (٥ <= ٣) { ن٣ = ١. }
    خ = خ + تحقق(ن٣, ٠).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٧. المتغيرات المحلية (Local Variables)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_متغيرات() {
    صحيح خ = ٠.
    صحيح أ = ١٠.
    أ = أ + ٥.
    خ = خ + تحقق(أ, ١٥).
    أ = أ * ٢.
    خ = خ + تحقق(أ, ٣٠).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٨. الثوابت العامة (Global Constants)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_ثوابت() {
    صحيح خ = ٠.
    خ = خ + تحقق(الحد, ١٠).
    خ = خ + تحقق(المعامل, ٣).
    خ = خ + تحقق(الحد * المعامل, ٣٠).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٩. إذا بسيط (Simple If)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_إذا() {
    صحيح خ = ٠.
    صحيح ن = ٠.
    إذا (١ == ١) {
        ن = ٤٢.
    }
    خ = خ + تحقق(ن, ٤٢).

    صحيح م = ١٠.
    إذا (م > ٥) {
        م = ٢٠.
    } وإلا {
        م = ٣٠.
    }
    خ = خ + تحقق(م, ٢٠).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ١٠. إذا / وإلا إذا / وإلا (If/ElseIf/Else)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_إذا_متعدد() {
    صحيح خ = ٠.
    صحيح ق = ٨٥.
    صحيح نتيجة = ٠.
    إذا (ق >= ٩٠) {
        نتيجة = ١.
    } وإلا إذا (ق >= ٨٠) {
        نتيجة = ٢.
    } وإلا إذا (ق >= ٧٠) {
        نتيجة = ٣.
    } وإلا {
        نتيجة = ٤.
    }
    خ = خ + تحقق(نتيجة, ٢).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ١١. حلقة طالما بسيطة (Simple While Loop)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_طالما_بسيط() {
    صحيح خ = ٠.
    صحيح مجموع = ٠.
    صحيح ع = ١.
    طالما (ع <= ١٠) {
        مجموع = مجموع + ع.
        ع = ع + ١.
    }
    خ = خ + تحقق(مجموع, ٥٥).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ١٢. حلقة طالما مع توقف (While + Break)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_طالما_توقف() {
    صحيح خ = ٠.
    صحيح ف = ٠.
    طالما (ف < ١٠٠) {
        إذا (ف == ٧) {
            توقف.
        }
        ف = ف + ١.
    }
    خ = خ + تحقق(ف, ٧).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ١٣. حلقة لكل بسيطة (Simple For Loop)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_لكل_بسيط() {
    صحيح خ = ٠.
    صحيح مجموع = ٠.
    لكل (صحيح ع = ٠؛ ع < ٥؛ ع = ع + ١) {
        مجموع = مجموع + ع.
    }
    خ = خ + تحقق(مجموع, ١٠).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ١٤. حلقة لكل مع توقف (For + Break)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_لكل_توقف() {
    صحيح خ = ٠.
    صحيح آخر = ٠.
    لكل (صحيح ع = ٠؛ ع < ١٠٠؛ ع = ع + ١) {
        إذا (ع == ٥) {
            توقف.
        }
        آخر = ع.
    }
    خ = خ + تحقق(آخر, ٤).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ١٥. اختر / حالة (Switch/Case)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_اختر() {
    صحيح خ = ٠.
    صحيح نتيجة = ٠.
    صحيح ق = ٢.
    اختر (ق) {
        حالة ١:
            نتيجة = ١٠.
            توقف.
        حالة ٢:
            نتيجة = ٢٠.
            توقف.
        حالة ٣:
            نتيجة = ٣٠.
            توقف.
        افتراضي:
            نتيجة = -١.
            توقف.
    }
    خ = خ + تحقق(نتيجة, ٢٠).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ١٦. اختر مع الحالة الافتراضية (Switch Default)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_اختر_افتراضي() {
    صحيح خ = ٠.
    صحيح نتيجة = ٠.
    صحيح ق = ٩٩.
    اختر (ق) {
        حالة ١:
            نتيجة = ١٠.
            توقف.
        افتراضي:
            نتيجة = -١.
            توقف.
    }
    خ = خ + تحقق(نتيجة, -١).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ١٧. دالة بدون معاملات (0-arg Function)
// ════════════════════════════════════════════════════════════════════════════
صحيح ثابت_خمسة() {
    إرجع ٥.
}

// ════════════════════════════════════════════════════════════════════════════
// ١٨. دالة بمعامل واحد (1-arg Function)
// ════════════════════════════════════════════════════════════════════════════
صحيح مربع(صحيح ن) {
    إرجع ن * ن.
}

// ════════════════════════════════════════════════════════════════════════════
// ١٩. دالة بمعاملين (2-arg Function)
// ════════════════════════════════════════════════════════════════════════════
صحيح جمع(صحيح أ, صحيح ب) {
    إرجع أ + ب.
}

// ════════════════════════════════════════════════════════════════════════════
// ٢٠. دالة بثلاث معاملات (3-arg Function)
// ════════════════════════════════════════════════════════════════════════════
صحيح مجموع_ثلاث(صحيح أ, صحيح ب, صحيح ج) {
    إرجع أ + ب + ج.
}

// ════════════════════════════════════════════════════════════════════════════
// ٢١. دالة بأربع معاملات (4-arg Function)
// ════════════════════════════════════════════════════════════════════════════
صحيح مجموع_أربع(صحيح أ, صحيح ب, صحيح ج, صحيح د) {
    إرجع أ + ب + ج + د.
}

صحيح اختبار_دوال() {
    صحيح خ = ٠.
    خ = خ + تحقق(ثابت_خمسة(), ٥).
    خ = خ + تحقق(مربع(٧), ٤٩).
    خ = خ + تحقق(جمع(٣, ٤), ٧).
    خ = خ + تحقق(مجموع_ثلاث(١, ٢, ٣), ٦).
    خ = خ + تحقق(مجموع_أربع(١, ٢, ٣, ٤), ١٠).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٢٢. التكرار: المضروب (Factorial - Recursion)
// ════════════════════════════════════════════════════════════════════════════
صحيح مضروب(صحيح ن) {
    إذا (ن <= ١) {
        إرجع ١.
    }
    إرجع ن * مضروب(ن - ١).
}

صحيح اختبار_مضروب() {
    صحيح خ = ٠.
    خ = خ + تحقق(مضروب(٠), ١).
    خ = خ + تحقق(مضروب(١), ١).
    خ = خ + تحقق(مضروب(٥), ١٢٠).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٢٣. التكرار: فيبوناتشي (Fibonacci - Recursion)
// ════════════════════════════════════════════════════════════════════════════
صحيح فيبوناتشي(صحيح ن) {
    إذا (ن <= ٠) {
        إرجع ٠.
    }
    إذا (ن == ١) {
        إرجع ١.
    }
    إرجع فيبوناتشي(ن - ١) + فيبوناتشي(ن - ٢).
}

صحيح اختبار_فيبوناتشي() {
    صحيح خ = ٠.
    خ = خ + تحقق(فيبوناتشي(٠), ٠).
    خ = خ + تحقق(فيبوناتشي(١), ١).
    خ = خ + تحقق(فيبوناتشي(٧), ١٣).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٢٤. استدعاء متداخل (Nested Function Calls)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_استدعاء_متداخل() {
    صحيح خ = ٠.
    خ = خ + تحقق(جمع(مربع(٣), مربع(٤)), ٢٥).
    خ = خ + تحقق(مربع(جمع(٢, ٣)), ٢٥).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٢٥. العمليات المنطقية: و (Logical AND)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_و() {
    صحيح خ = ٠.
    صحيح نتيجة = ٠.

    // true AND true
    إذا (١ == ١ && ٢ == ٢) {
        نتيجة = ١.
    } وإلا {
        نتيجة = ٠.
    }
    خ = خ + تحقق(نتيجة, ١).

    // true AND false
    إذا (١ == ١ && ٢ == ٣) {
        نتيجة = ١.
    } وإلا {
        نتيجة = ٠.
    }
    خ = خ + تحقق(نتيجة, ٠).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٢٦. العمليات المنطقية: أو (Logical OR)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_أو() {
    صحيح خ = ٠.
    صحيح نتيجة = ٠.

    // false OR true
    إذا (١ == ٢ || ٣ == ٣) {
        نتيجة = ١.
    } وإلا {
        نتيجة = ٠.
    }
    خ = خ + تحقق(نتيجة, ١).

    // false OR false
    إذا (١ == ٢ || ٣ == ٤) {
        نتيجة = ١.
    } وإلا {
        نتيجة = ٠.
    }
    خ = خ + تحقق(نتيجة, ٠).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٢٧. مقارنة مركبة مع و (Compound Comparison with AND)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_مقارنة_مركبة() {
    صحيح خ = ٠.
    صحيح س = ٥.
    صحيح نتيجة = ٠.
    إذا (س > ٠ && س < ١٠) {
        نتيجة = ١.
    } وإلا {
        نتيجة = ٠.
    }
    خ = خ + تحقق(نتيجة, ١).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٢٨. الطباعة (Print - no-fail, just ensure no crash)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_طباعة() {
    اطبع ٤٢.
    اطبع "مرحبا".
    صحيح ق = ١٢٣.
    اطبع ق.
    إرجع ٠.
}

// ════════════════════════════════════════════════════════════════════════════
// ٢٩. شرط متعدد المستويات (Multi-level Conditions)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_متعدد() {
    صحيح خ = ٠.
    صحيح ق = ٥٠.
    صحيح فئة = ٠.
    إذا (ق >= ٩٠) {
        فئة = ١.
    } وإلا إذا (ق >= ٧٠) {
        فئة = ٢.
    } وإلا إذا (ق >= ٥٠) {
        فئة = ٣.
    } وإلا {
        فئة = ٤.
    }
    خ = خ + تحقق(فئة, ٣).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٣٠. حالات حدودية (Edge Cases)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_حدود() {
    صحيح خ = ٠.
    خ = خ + تحقق(٠, ٠).
    خ = خ + تحقق(-١ + ١, ٠).
    خ = خ + تحقق(٣ / ١٠, ٠).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٣١. المتغيرات العامة: القراءة والكتابة (Global Variable Read/Write)
// ════════════════════════════════════════════════════════════════════════════
صحيح زد_المتغير(صحيح قيمة) {
    متغير_عام = متغير_عام + قيمة.
    إرجع متغير_عام.
}

صحيح اختبار_عامة() {
    صحيح خ = ٠.
    خ = خ + تحقق(متغير_عام, ٠).
    زد_المتغير(١٠).
    خ = خ + تحقق(متغير_عام, ١٠).
    زد_المتغير(٥).
    خ = خ + تحقق(متغير_عام, ١٥).
    متغير_عام = ١٠٠.
    خ = خ + تحقق(متغير_عام, ١٠٠).
    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٣٥. نوع الحرف (Character Type) — v0.3.5
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_حرف() {
    صحيح خ = ٠.

    حرف ح = 'أ'.
    صحيح س = ح.
    خ = خ + تحقق(س, ١٥٧١). // U+0623

    ح = 'ب'.
    س = ح.
    خ = خ + تحقق(س, ١٥٧٦). // U+0628

    // اختبار switch على حرف
    صحيح ن = ٠.
    اختر(ح) {
        حالة 'أ':
            ن = ١.
            توقف.
        حالة 'ب':
            ن = ٢.
            توقف.
        افتراضي:
            ن = ٣.
    }
    خ = خ + تحقق(ن, ٢).

    // اختبار حرف عام
    صحيح ع = حرف_عام.
    خ = خ + تحقق(ع, ١٥٧١).

    // يجب أن يطبع الحرف كـ UTF-8
    اطبع ح.

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٦.١ مقارنات/تحويلات موقّع/غير موقّع (Signed/Unsigned) — v0.3.5.5
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_مقارنات_غير_موقعة_٣٢() {
    صحيح خ = ٠.

    ط٣٢ غير_موقّع = ١.
    ص٣٢ موقّع = -١.

    صحيح ن١ = (غير_موقّع < موقّع).
    صحيح ن٢ = (غير_موقّع > موقّع).
    خ = خ + تحقق(ن١, ١).
    خ = خ + تحقق(ن٢, ٠).

    ط٣٢ أقصى = ٤٢٩٤٩٦٧٢٩٥.
    ص٣٢ واحد = ١.
    ص٣٢ صفر = ٠.
    صحيح التفاف = ((أقصى + واحد) == صفر).
    خ = خ + تحقق(التفاف, ١).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٣٦. النص كـ حرف[] + فهرسة (String-Char Relationship) — v0.3.5
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_نص_كحروف() {
    صحيح خ = ٠.

    حرف ح٠ = نص_عام[٠].
    حرف ح١ = نص_عام[١].

    صحيح س٠ = ح٠.
    صحيح س١ = ح١.

    خ = خ + تحقق(س٠, ١٥٧١). // 'أ'
    خ = خ + تحقق(س١, ١٥٧٦). // 'ب'

    اطبع نص_عام.

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٣٧. نوع العشري (Float) — v0.3.5 (تخزين/ثوابت فقط)
// ════════════════════════════════════════════════════════════════════════════
عشري جمع_عشري(عشري أ, عشري ب) {
    إرجع أ + ب.
}

عشري مزج_عشري(صحيح أ, عشري ب, صحيح ج) {
    إرجع أ + ب + ج.
}

صحيح اختبار_عشري() {
    صحيح خ = ٠.

    عشري ف = ٠.٥.
    عشري س = -٠.٥.
    عشري ت = ٣.٠.

    عشري ن = ف + ت.
    صحيح ن١ = ن * ٢.
    خ = خ + تحقق(ن١, ٧).

    عشري ق = ت / ٢.
    صحيح ق١ = ق * ٤.
    خ = خ + تحقق(ق١, ٦).

    صحيح م١ = (ف < ت).
    صحيح م٢ = (ف <= ف).
    صحيح م٣ = (ف == ف).
    صحيح م٤ = (ف != س).
    صحيح م٥ = (ت > ف).
    صحيح م٦ = (ت >= ت).
    خ = خ + تحقق(م١, ١).
    خ = خ + تحقق(م٢, ١).
    خ = خ + تحقق(م٣, ١).
    خ = خ + تحقق(م٤, ١).
    خ = خ + تحقق(م٥, ١).
    خ = خ + تحقق(م٦, ١).

    // NaN: كل المقارنات المرتبة يجب أن تُرجع خطأ، و (NaN != NaN) يجب أن تكون صحيحة.
    عشري نان = ٠.٠ / ٠.٠.
    صحيح نان١ = (نان == نان).
    صحيح نان٢ = (نان != نان).
    صحيح نان٣ = (نان < ت).
    صحيح نان٤ = (نان >= ت).
    خ = خ + تحقق(نان١, ٠).
    خ = خ + تحقق(نان٢, ١).
    خ = خ + تحقق(نان٣, ٠).
    خ = خ + تحقق(نان٤, ٠).

    اطبع ن.

    عشري ر = جمع_عشري(١.٢٥، ٢.٥).
    صحيح ر١ = ر * ٤.
    خ = خ + تحقق(ر١, ١٥).

    عشري ز = مزج_عشري(٢، ٠.٥، ٣).
    صحيح ز١ = ز * ٢.
    خ = خ + تحقق(ز١, ١١).

    // إبقاء هذه المتغيرات مستخدمة.
    ف = ف.
    س = س.
    ت = عشري_عام.
    ت = ت.

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٣٨. أنواع الأعداد الصحيحة الموقعة (Signed Integer Types: ص٨، ص١٦، ص٣٢، ص٦٤)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_أنواع_صحيحة_موقعة() {
    صحيح خ = ٠.

    // ص٨ (int8_t)
    ص٨ صغير = ١٢٧.
    خ = خ + تحقق(صغير، ١٢٧).
    ص٨ سالب_صغير = -١٢٨.
    صحيح س = سالب_صغير.
    خ = خ + تحقق(س، -١٢٨).

    // ص١٦ (int16_t)
    ص١٦ متوسط = ٣٢٧٦٧.
    خ = خ + تحقق(متوسط، ٣٢٧٦٧).
    ص١٦ سالب_متوسط = -٣٢٧٦٨.
    صحيح م = سالب_متوسط.
    خ = خ + تحقق(م، -٣٢٧٦٨).

    // ص٣٢ (int32_t)
    ص٣٢ كبير = ٢١٤٧٤٨٣٦٤٧.
    صحيح ك = كبير / ١٠٠٠٠٠٠٠.
    خ = خ + تحقق(ك، ٢١٤٧).
    ص٣٢ سالب_كبير = -٢١٤٧٤٨٣٦٤٨.
    صحيح سك = سالب_كبير / ١٠٠٠٠٠٠٠.
    خ = خ + تحقق(سك، -٢١٤٧).

    // ص٦٤ (int64_t)
    ص٦٤ ضخم = ٩٢٢٣٣٧٢٠٣٦٨٥٤٧٧٥٨٠٧.
    صحيح ض = ضخم / ١٠٠٠٠٠٠٠٠٠٠٠٠٠٠.
    خ = خ + تحقق(ض، ٩٢٢٣٣٧).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٣٩. أنواع الأعداد الصحيحة غير الموقعة (Unsigned Integer Types: ط٨، ط١٦، ط٣٢، ط٦٤)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_أنواع_صحيحة_غير_موقعة() {
    صحيح خ = ٠.

    // ط٨ (uint8_t)
    ط٨ صغير_غير_موقّع = ٢٥٥.
    خ = خ + تحقق(صغير_غير_موقّع، ٢٥٥).
    ط٨ صفر_ط = ٠.
    خ = خ + تحقق(صفر_ط، ٠).

    // ط١٦ (uint16_t)
    ط١٦ متوسط_غير_موقّع = ٦٥٥٣٥.
    خ = خ + تحقق(متوسط_غير_موقّع، ٦٥٥٣٥).

    // ط٣٢ (uint32_t)
    ط٣٢ كبير_غير_موقّع = ٤٢٩٤٩٦٧٢٩٥.
    صحيح كغ = كبير_غير_موقّع / ١٠٠٠٠٠٠٠.
    خ = خ + تحقق(كغ، ٤٢٩٤).

    // ط٦٤ (uint64_t)
    ط٦٤ ضخم_غير_موقّع = ١٨٤٤٦٧٤٤٠٧٣٧٠٩٥٥١٦١٥.
    صحيح ضغ = ضخم_غير_موقّع / ١٠٠٠٠٠٠٠٠٠٠٠٠٠٠.
    خ = خ + تحقق(ضغ، ١٨٤٤٦٧٤).

    // المقارنات غير الموقعة
    ط٣٢ أ = ٥.
    ط٣٢ ب = ١٠.
    صحيح نت = (أ < ب).
    خ = خ + تحقق(نت، ١).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٤٠. نوع منطقي (Bool Type)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_منطقي() {
    صحيح خ = ٠.

    منطقي صح = صواب.
    منطقي خط = خطأ.

    // التحقق من القيم
    صحيح ن١ = صح.
    صحيح ن٢ = خط.
    خ = خ + تحقق(ن١، ١).
    خ = خ + تحقق(ن٢، ٠).

    // استخدام في الشرط
    صحيح نتيجة = ٠.
    إذا (صح) {
        نتيجة = ١.
    }
    خ = خ + تحقق(نتيجة، ١).

    نتيجة = ١.
    إذا (خط) {
        نتيجة = ٠.
    }
    خ = خ + تحقق(نتيجة، ١).

    // العمليات المنطقية
    منطقي ومنطقي = صح && صح.
    منطقي أومنطقي = صح || خط.
    منطقي نفي = !صح.

    خ = خ + تحقق(ومنطقي، ١).
    خ = خ + تحقق(أومنطقي، ١).
    خ = خ + تحقق(نفي، ٠).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٤١. معامل الباقي (Modulo Operator: %)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_باقي_القسمة() {
    صحيح خ = ٠.

    خ = خ + تحقق(١٠ % ٣، ١).
    خ = خ + تحقق(١٥ % ٤، ٣).
    خ = خ + تحقق(١٠٠ % ١٠، ٠).
    خ = خ + تحقق(٧ % ٥، ٢).
    خ = خ + تحقق(١٧ % ٥، ٢).

    // مع أرقام سالبة
    خ = خ + تحقق(-١٠ % ٣، -١).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٤٢. العمليات على المستوى البتّي (Bitwise Operators: &، |، ^، <<، >>، ~)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_عمليات_بتية() {
    صحيح خ = ٠.

    // AND (&)
    خ = خ + تحقق(٥ & ٣، ١).   // 101 & 011 = 001
    خ = خ + تحقق(٧ & ٧، ٧).   // 111 & 111 = 111
    خ = خ + تحقق(١٢ & ١٠، ٨). // 1100 & 1010 = 1000

    // OR (|)
    خ = خ + تحقق(٥ | ٣، ٧).    // 101 | 011 = 111
    خ = خ + تحقق(٤ | ٢، ٦).    // 100 | 010 = 110
    خ = خ + تحقق(٠ | ٥، ٥).

    // XOR (^)
    خ = خ + تحقق(٥ ^ ٣، ٦).    // 101 ^ 011 = 110
    خ = خ + تحقق(٧ ^ ٧، ٠).    // 111 ^ 111 = 000
    خ = خ + تحقق(٤ ^ ١، ٥).    // 100 ^ 001 = 101

    // Left Shift (<<)
    خ = خ + تحقق(١ << ٢، ٤).   // 1 << 2 = 4
    خ = خ + تحقق(٣ << ١، ٦).   // 11 << 1 = 110
    خ = خ + تحقق(٥ << ٠، ٥).

    // Right Shift (>>)
    خ = خ + تحقق(٨ >> ٢، ٢).   // 1000 >> 2 = 10
    خ = خ + تحقق(٧ >> ١، ٣).   // 111 >> 1 = 11
    خ = خ + تحقق(١٦ >> ٣، ٢).

    // NOT (~)
    خ = خ + تحقق(~٠، -١).
    خ = خ + تحقق(~١، -٢).
    خ = خ + تحقق(~(-١)، ٠).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٤٣. الزيادة والنقصان اللاحقة (Postfix Increment/Decrement: ++، --)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_زيادة_لاحقة() {
    صحيح خ = ٠.

    // postfix increment
    صحيح ن = ٥.
    صحيح ق = ن++.
    خ = خ + تحقق(ق، ٥).   // القيمة القديمة
    خ = خ + تحقق(ن، ٦).   // بعد الزيادة

    // postfix decrement
    صحيح م = ١٠.
    صحيح د = م--.
    خ = خ + تحقق(د، ١٠).  // القيمة القديمة
    خ = خ + تحقق(م، ٩).   // بعد النقصان

    // في حلقة
    صحيح مجموع = ٠.
    صحيح ع = ٠.
    طالما (ع < ٥) {
        مجموع = مجموع + ع++.
    }
    خ = خ + تحقق(مجموع، ١٠). // ٠+١+٢+٣+٤

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٤٤. معامل العنوان والإحالة (Address-of & and Dereference *)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_عنوان_وإحالة() {
    صحيح خ = ٠.

    صحيح ن = ٤٢.
    صحيح* مؤشر = &ن.
    صحيح ق = *مؤشر.
    خ = خ + تحقق(ق، ٤٢).

    // تعديل عبر المؤشر
    *مؤشر = ١٠٠.
    خ = خ + تحقق(ن، ١٠٠).

    // مؤشر لمؤشر
    صحيح** مؤشر_مؤشر = &مؤشر.
    خ = خ + تحقق(**مؤشر_مؤشر، ١٠٠).

    // مع مصفوفة
    صحيح مصفوفة[٥] = {١٠، ٢٠، ٣٠، ٤٠، ٥٠}.
    صحيح* بداية = &مصفوفة[٠].
    خ = خ + تحقق(*بداية، ١٠).
    خ = خ + تحقق(*(بداية + ١)، ٢٠).
    خ = خ + تحقق(*(بداية + ٤)، ٥٠).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٤٥. عبارة الاستمرار في الحلقات (Continue Statement)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_استمرار_طالما() {
    صحيح خ = ٠.

    // تجاوز الأعداد الفردية
    صحيح مجموع = ٠.
    صحيح ع = ٠.
    طالما (ع < ١٠) {
        ع = ع + ١.
        إذا (ع % ٢ != ٠) {
            استمر.
        }
        مجموع = مجموع + ع.
    }
    خ = خ + تحقق(مجموع، ٣٠). // ٢+٤+٦+٨+١٠

    إرجع خ.
}

صحيح اختبار_استمرار_لكل() {
    صحيح خ = ٠.

    // تجاوز مضاعفات ٣
    صحيح مجموع = ٠.
    لكل (صحيح ع = ١؛ ع <= ١٠؛ ع = ع + ١) {
        إذا (ع % ٣ == ٠) {
            استمر.
        }
        مجموع = مجموع + ع.
    }
    خ = خ + تحقق(مجموع، ٣٧). // ١+٢+٤+٥+٧+٨+١٠

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٤٦. الحلقات المتداخلة مع توقف واستمرار (Nested Loops with Break/Continue)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_حلقات_متداخلة() {
    صحيح خ = ٠.

    // توقف داخلي
    صحيح عداد = ٠.
    لكل (صحيح س = ٠؛ س < ٥؛ س = س + ١) {
        لكل (صحيح ص = ٠؛ ص < ٥؛ ص = ص + ١) {
            عداد = عداد + ١.
            إذا (ص == ٢) {
                توقف.
            }
        }
    }
    // ٥×٣ = ١٥ (توقف عند ص==٢)
    خ = خ + تحقق(عداد، ١٥).

    // استمرار داخلي
    عداد = ٠.
    لكل (صحيح س = ٠؛ س < ٣؛ س = س + ١) {
        لكل (صحيح ص = ٠؛ ص < ٣؛ ص = ص + ١) {
            إذا (ص == ١) {
                استمر.
            }
            عداد = عداد + ١.
        }
    }
    // ٣×٢ = ٦ (تخطي ص==١)
    خ = خ + تحقق(عداد، ٦).

    // while متداخلة
    عداد = ٠.
    صحيح خارجي = ٠.
    طالما (خارجي < ٣) {
        صحيح داخلي = ٠.
        طالما (داخلي < ٣) {
            داخلي = داخلي + ١.
            إذا (داخلي == ٢) {
                استمر.
            }
            عداد = عداد + ١.
        }
        خارجي = خارجي + ١.
    }
    // ٣×٢ = ٦
    خ = خ + تحقق(عداد، ١٢).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٤٧. الأسماء المستعارة للأنواع (Type Aliases)
// ════════════════════════════════════════════════════════════════════════════
نوع عدد_صحيح = صحيح.
نوع عدد_عشري = عشري.
نوع علمي = منطقي.
نوع حرف_عربي = حرف.

صحيح اختبار_أسماء_مستعارة() {
    صحيح خ = ٠.

    عدد_صحيح ن = ٤٢.
    خ = خ + تحقق(ن، ٤٢).

    عدد_عشري ع = ٣.٥.
    صحيح ع٢ = ع * ٢.
    خ = خ + تحقق(ع٢، ٧).

    علمي ص = صواب.
    خ = خ + تحقق(ص، ١).

    حرف_عربي ح = 'ج'.
    صحيح رمز = ح.
    خ = خ + تحقق(رمز، ١٥٨٧).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٤٨. مؤشرات الدوال (Function Pointers)
// ════════════════════════════════════════════════════════════════════════════
صحيح دالة_للمؤشر(صحيح أ، صحيح ب) {
    إرجع أ + ب.
}

صحيح دالة_ضرب(صحيح أ، صحيح ب) {
    إرجع أ * ب.
}

صحيح اختبار_مؤشرات_دوال() {
    صحيح خ = ٠.

    // تعريف مؤشر دالة واستدعائها
    دالة(صحيح، صحيح) -> صحيح مؤشر = دالة_للمؤشر.
    صحيح ن = مؤشر(٣، ٤).
    خ = خ + تحقق(ن، ٧).

    // تغيير المؤشر
    مؤشر = دالة_ضرب.
    ن = مؤشر(٣، ٤).
    خ = خ + تحقق(ن، ١٢).

    // مقارنة المؤشرات
    دالة(صحيح، صحيح) -> صحيح مؤشر٢ = دالة_للمؤشر.
    منطقي متساويان = (مؤشر == دالة_ضرب).
    خ = خ + تحقق(متساويان، ١).

    منطقي مختلفان = (مؤشر != مؤشر٢).
    خ = خ + تحقق(مختلفان، ١).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٤٩. المتغيرات الساكنة (Static Variables)
// ════════════════════════════════════════════════════════════════════════════
صحيح دالة_ساكنة() {
    ساكن صحيح عداد = ٠.
    عداد = عداد + ١.
    إرجع عداد.
}

صحيح اختبار_ساكن() {
    صحيح خ = ٠.

    // كل استدعاء يحتفظ بالقيمة السابقة
    خ = خ + تحقق(دالة_ساكنة()، ١).
    خ = خ + تحقق(دالة_ساكنة()، ٢).
    خ = خ + تحقق(دالة_ساكنة()، ٣).
    خ = خ + تحقق(دالة_ساكنة()، ٤).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٥٠. التحويل بين الأنواع (Casting with كـ)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_تحويل_أنواع() {
    صحيح خ = ٠.

    // تحويل عشري إلى صحيح
    عشري ع = ٣.٩.
    صحيح ص = ع كـ صحيح.
    خ = خ + تحقق(ص، ٣).

    // تحويل صحيح إلى عشري
    صحيح ن = ٥.
    عشري ع٢ = ن كـ عشري.
    صحيح نت = ع٢ * ٢.
    خ = خ + تحقق(نت، ١٠).

    // تحويل بين أنواع الأعداد
    ص٦٤ كبير = ١٠٠٠.
    صحيح صغ = كبير كـ صحيح.
    خ = خ + تحقق(صغ، ١٠٠٠).

    ط٣٢ غير_موقّع = ٢٠٠.
    صحيح موقّع = غير_موقّع كـ صحيح.
    خ = خ + تحقق(موقّع، ٢٠٠).

    // تحويل مؤشرات
    صحيح قيمة = ٤٢.
    صحيح* مؤشر = &قيمة.
    ط٦٤ عنوان = مؤشر كـ ط٦٤.
    صحيح* مؤشر_مرة_أخرى = عنوان كـ صحيح*.
    خ = خ + تحقق(*مؤشر_مرة_أخرى، ٤٢).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٥١. معامل الحجم (Sizeof: حجم)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_حجم() {
    صحيح خ = ٠.

    // حجم الأنواع الأساسية
    خ = خ + تحقق(حجم(صحيح)، ٨).    // ٨ بايت على x86_64
    خ = خ + تحقق(حجم(ص٨)، ١).
    خ = خ + تحقق(حجم(ص١٦)، ٢).
    خ = خ + تحقق(حجم(ص٣٢)، ٤).
    خ = خ + تحقق(حجم(ص٦٤)، ٨).
    خ = خ + تحقق(حجم(ط٨)، ١).
    خ = خ + تحقق(حجم(ط١٦)، ٢).
    خ = خ + تحقق(حجم(ط٣٢)، ٤).
    خ = خ + تحقق(حجم(ط٦٤)، ٨).
    خ = خ + تحقق(حجم(عشري)، ٨).
    خ = خ + تحقق(حجم(حرف)، ٤).     // UTF-32
    خ = خ + تحقق(حجم(منطقي)، ١).

    // حجم المؤشرات
    خ = خ + تحقق(حجم(صحيح*)، ٨).
    خ = خ + تحقق(حجم(عشري*)، ٨).

    // حجم المتغيرات
    صحيح ن = ٠.
    خ = خ + تحقق(حجم(ن)، ٨).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٥٢. المصفوفات متعددة الأبعاد (Multi-dimensional Arrays)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_مصفوفات_متعددة() {
    صحيح خ = ٠.

    // مصفوفة ثنائية الأبعاد
    صحيح مصفوفة[٣][٣] = {
        {١، ٢، ٣}،
        {٤، ٥، ٦}،
        {٧، ٨، ٩}
    }.

    خ = خ + تحقق(مصفوفة[٠][٠]، ١).
    خ = خ + تحقق(مصفوفة[٠][٢]، ٣).
    خ = خ + تحقق(مصفوفة[١][١]، ٥).
    خ = خ + تحقق(مصفوفة[٢][٢]، ٩).

    // تعديل القيم
    مصفوفة[١][١] = ١٠٠.
    خ = خ + تحقق(مصفوفة[١][١]، ١٠٠).

    // مصفوفة غير منتظمة
    صحيح مصفوفة٢[٢][٤] = {
        {١، ٢، ٣، ٤}،
        {٥، ٦، ٧، ٨}
    }.
    خ = خ + تحقق(مصفوفة٢[١][٣]، ٨).

    // حساب المجموع
    صحيح مجموع = ٠.
    لكل (صحيح س = ٠؛ س < ٣؛ س = س + ١) {
        لكل (صحيح ص = ٠؛ ص < ٣؛ ص = ص + ١) {
            إذا (س == ١ && ص == ١) {
                مجموع = مجموع + ١٠٠.
            } وإلا {
                مجموع = مجموع + مصفوفة[س][ص].
            }
        }
    }
    خ = خ + تحقق(مجموع، ١٤٥). // ١+٢+٣+٤+١٠٠+٦+٧+٨+٩ = ١٤٥

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٥٣. عمليات النصوص (String Operations)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_عمليات_نصوص() {
    صحيح خ = ٠.

    // المقارنات
    نص ن١ = "أهلاً".
    نص ن٢ = "أهلاً".
    نص ن٣ = "مرحباً".

    صحيح متساويان = (ن١ == ن٢).
    خ = خ + تحقق(متساويان، ١).

    صحيح مختلفان = (ن١ != ن٣).
    خ = خ + تحقق(مختلفان، ١).

    صحيح أصغر = (ن١ < ن٣).
    خ = خ + تحقق(أصغر، ١).

    // طول النص
    نص فارغ = "".
    نص حرف_واحد = "أ".
    نص جملة = "السلام عليكم".

    // تكرار النص
    نص مكرر = ن١ * ٣.
    // "أهلاً" * ٣ = "أهلاًأهلاًأهلاً"

    // الفهرسة
    حرف ح = ن١[٠].
    صحيح رمز = ح.
    خ = خ + تحقق(رمز، ١٥٧٥). // 'أ' = U+0623

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٥٤. حساب المؤشرات (Pointer Arithmetic)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_حساب_مؤشرات() {
    صحيح خ = ٠.

    صحيح مصفوفة[٥] = {١٠، ٢٠، ٣٠، ٤٠، ٥٠}.
    صحيح* م = &مصفوفة[٠].

    // الجمع
    خ = خ + تحقق(*م، ١٠).
    خ = خ + تحقق(*(م + ١)، ٢٠).
    خ = خ + تحقق(*(م + ٤)، ٥٠).

    // الزيادة
    صحيح* م٢ = م.
    م٢ = م٢ + ٢.
    خ = خ + تحقق(*م٢، ٣٠).

    // الطرح
    صحيح* م٣ = م + ٤.
    خ = خ + تحقق(*م٣، ٥٠).
    م٣ = م٣ - ٢.
    خ = خ + تحقق(*م٣، ٣٠).

    // الفرق بين مؤشرين
    صحيح* بداية = م.
    صحيح* نهاية = م + ٤.
    صحيح فرق = نهاية - بداية.
    خ = خ + تحقق(فرق، ٤).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٥٥. المؤشر الفارغ (Null Pointer)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_مؤشر_فارغ() {
    صحيح خ = ٠.

    صحيح* مؤشر = عدم.
    صحيح فارغ = (مؤشر == عدم).
    خ = خ + تحقق(فارغ، ١).

    منطقي ليس_فارغ = (مؤشر != عدم).
    خ = خ + تحقق(ليس_فارغ، ٠).

    // المقارنة مع صفر
    فارغ = (مؤشر == ٠).
    خ = خ + تحقق(فارغ، ١).

    // إسناد قيمة ثم التحقق
    صحيح قيمة = ٤٢.
    مؤشر = &قيمة.
    ليس_فارغ = (مؤشر != عدم).
    خ = خ + تحقق(ليس_فارغ، ١).

    // العودة للفارغ
    مؤشر = عدم.
    فارغ = (مؤشر == عدم).
    خ = خ + تحقق(فارغ، ١).

    إرجع خ.
}

// ════════════════════════════════════════════════════════════════════════════
// ٥٦. إضافات على العمليات المنطقية (Logical NOT: !)
// ════════════════════════════════════════════════════════════════════════════
صحيح اختبار_نفي_منطقي() {
    صحيح خ = ٠.

    // نفي القيم
    خ = خ + تحقق(!٠، ١).
    خ = خ + تحقق(!١، ٠).
    خ = خ + تحقق(!٥، ٠).     // أي قيمة غير صفر = صح
    خ = خ + تحقق(!(-١)، ٠).

    // في شروط
    صحيح ن = ٠.
    إذا (!ن) {
        ن = ١.
    }
    خ = خ + تحقق(ن، ١).

    // نفي شرط
    إذا (!(ن == ٢)) {
        ن = ٢.
    }
    خ = خ + تحقق(ن، ٢).

    إرجع خ.
}

// ============================================================================
// الدالة الرئيسية (Main)
// ============================================================================

صحيح الرئيسية() {
    صحيح إجمالي = ٠.

    اطبع "=== اختبار الخلفية الشامل ===".

    إجمالي = إجمالي + اختبار_جمع_طرح().
    إجمالي = إجمالي + اختبار_ضرب().
    إجمالي = إجمالي + اختبار_قسمة().
    إجمالي = إجمالي + اختبار_سالب().
    إجمالي = إجمالي + اختبار_مقارنات().
    إجمالي = إجمالي + اختبار_مقارنات٢().
    إجمالي = إجمالي + اختبار_مقارنات_غير_موقعة_٣٢().
    إجمالي = إجمالي + اختبار_متغيرات().
    إجمالي = إجمالي + اختبار_ثوابت().
    إجمالي = إجمالي + اختبار_إذا().
    إجمالي = إجمالي + اختبار_إذا_متعدد().
    إجمالي = إجمالي + اختبار_طالما_بسيط().
    إجمالي = إجمالي + اختبار_طالما_توقف().
    إجمالي = إجمالي + اختبار_لكل_بسيط().
    إجمالي = إجمالي + اختبار_لكل_توقف().
    إجمالي = إجمالي + اختبار_اختر().
    إجمالي = إجمالي + اختبار_اختر_افتراضي().
    إجمالي = إجمالي + اختبار_دوال().
    إجمالي = إجمالي + اختبار_مضروب().
    إجمالي = إجمالي + اختبار_فيبوناتشي().
    إجمالي = إجمالي + اختبار_استدعاء_متداخل().
    إجمالي = إجمالي + اختبار_و().
    إجمالي = إجمالي + اختبار_أو().
    إجمالي = إجمالي + اختبار_مقارنة_مركبة().
    إجمالي = إجمالي + اختبار_طباعة().
    إجمالي = إجمالي + اختبار_متعدد().
    إجمالي = إجمالي + اختبار_حدود().
    إجمالي = إجمالي + اختبار_عامة().

    // ميزات v0.3.3/v0.3.4
    إجمالي = إجمالي + اختبار_معالج_قبلي().
    إجمالي = إجمالي + اختبار_تهيئة_مصفوفة_محلية().
    إجمالي = إجمالي + اختبار_تهيئة_مصفوفة_عامة().
    إجمالي = إجمالي + اختبار_تعداد().
    إجمالي = إجمالي + اختبار_هيكل_محلي().
    إجمالي = إجمالي + اختبار_هيكل_عام().
    إجمالي = إجمالي + اختبار_اتحاد().

    // v0.3.5
    إجمالي = إجمالي + اختبار_حرف().
    إجمالي = إجمالي + اختبار_نص_كحروف().
    إجمالي = إجمالي + اختبار_عشري().

    // أنواع الأعداد الصحيحة الموقعة وغير الموقعة
    إجمالي = إجمالي + اختبار_أنواع_صحيحة_موقعة().
    إجمالي = إجمالي + اختبار_أنواع_صحيحة_غير_موقعة().

    // النوع المنطقي
    إجمالي = إجمالي + اختبار_منطقي().

    // المعاملات الإضافية
    إجمالي = إجمالي + اختبار_باقي_القسمة().
    إجمالي = إجمالي + اختبار_عمليات_بتية().
    إجمالي = إجمالي + اختبار_زيادة_لاحقة().
    إجمالي = إجمالي + اختبار_عنوان_وإحالة().
    إجمالي = إجمالي + اختبار_نفي_منطقي().

    // التحكم في الحلقات
    إجمالي = إجمالي + اختبار_استمرار_طالما().
    إجمالي = إجمالي + اختبار_استمرار_لكل().
    إجمالي = إجمالي + اختبار_حلقات_متداخلة().

    // الميزات المتقدمة
    إجمالي = إجمالي + اختبار_أسماء_مستعارة().
    إجمالي = إجمالي + اختبار_مؤشرات_دوال().
    إجمالي = إجمالي + اختبار_ساكن().
    إجمالي = إجمالي + اختبار_تحويل_أنواع().
    إجمالي = إجمالي + اختبار_حجم().
    إجمالي = إجمالي + اختبار_مصفوفات_متعددة().
    إجمالي = إجمالي + اختبار_عمليات_نصوص().
    إجمالي = إجمالي + اختبار_حساب_مؤشرات().
    إجمالي = إجمالي + اختبار_مؤشر_فارغ().

    // ─── الملخص ───
    اطبع "=== النتائج ===".
    اطبع "عدد الاختبارات:".
    اطبع عد.
    اطبع "عدد الأخطاء:".
    اطبع إجمالي.

    إذا (إجمالي == ٠) {
        اطبع "PASS".
    } وإلا {
        اطبع "FAIL".
    }

    إرجع إجمالي.
}
