تعداد وضع_تشغيل {
    جاهز،
    متوقف،
}

هيكل نقطة {
    صحيح س.
    صحيح ص.
}

اتحاد قيمة {
    صحيح رقم.
    ط٨ علم.
}

نوع معرف = ط٦٤.
نوع إحداثي = ص٣٢.
نوع حالة_تشغيل = تعداد وضع_تشغيل.
نوع نقطة_نوع = هيكل نقطة.
نوع قيمة_نوع = اتحاد قيمة.
نوع معرف_ثان = معرف.

معرف رقم_عام = ٥.

صحيح الرئيسية() {
    معرف_ثان أ = ٤٠.
    إحداثي ب = -٣.
    حالة_تشغيل ح = وضع_تشغيل:جاهز.
    نقطة_نوع ن.
    قيمة_نوع ق.

    ن:س = أ + ١.
    ن:ص = ب.
    ق:رقم = ٧.

    إذا (رقم_عام != ٥) { إرجع ١. }
    إذا (ح != وضع_تشغيل:جاهز) { إرجع ٢. }
    إذا (ن:س != ٤١) { إرجع ٣. }
    إذا (ن:ص != -٣) { إرجع ٤. }
    إذا (ق:رقم != ٧) { إرجع ٥. }

    إرجع ٠.
}
