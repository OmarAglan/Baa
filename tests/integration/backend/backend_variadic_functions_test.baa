// RUN: runtime

#تضمين "stdlib/baalib.baahd"

صحيح جمع_متغير(صحيح عدد، ...) {
    قائمة_معاملات قائمة = عدم.
    بدء_معاملات(قائمة، عدد).

    صحيح مجموع = ٠.
    لكل (صحيح ف = ٠؛ ف < عدد؛ ف++) {
        مجموع = مجموع + معامل_تالي(قائمة، صحيح).
    }

    نهاية_معاملات(قائمة).
    إرجع مجموع.
}

عشري جمع_عشري_متغير(صحيح عدد، ...) {
    قائمة_معاملات قائمة = عدم.
    بدء_معاملات(قائمة، عدد).

    عشري مجموع = ٠.
    لكل (صحيح ف = ٠؛ ف < عدد؛ ف++) {
        مجموع = مجموع + معامل_تالي(قائمة، عشري).
    }

    نهاية_معاملات(قائمة).
    إرجع مجموع.
}

صحيح تحقق_نصين(صحيح عدد، ...) {
    قائمة_معاملات قائمة = عدم.
    بدء_معاملات(قائمة، عدد).

    نص أ = معامل_تالي(قائمة، نص).
    نص ب = معامل_تالي(قائمة، نص).

    نهاية_معاملات(قائمة).

    إذا (قارن_نص(أ، "مرحبا") != ٠) { إرجع ٠. }
    إذا (قارن_نص(ب، "باء") != ٠) { إرجع ٠. }
    إرجع ١.
}

صحيح الرئيسية() {
    إذا (جمع_متغير(٤، ١، ٢، ٣، ٤) != ١٠) {
        إرجع ١.
    }

    إذا (جمع_عشري_متغير(٢، ١.٥، ٢.٥) != ٤) {
        إرجع ٢.
    }

    إذا (تحقق_نصين(٢، "مرحبا"، "باء") != ١) {
        إرجع ٣.
    }

    إرجع ٠.
}
