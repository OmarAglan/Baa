// اختبار أحجام الأعداد الصحيحة (v0.3.5.5)

صحيح الرئيسية() {
    ص٨ س = -5.
    ط٨ ت = 250.
    ص١٦ ج = -300.
    ط١٦ د = 60000.
    ص٣٢ ه = -2000000000.
    ط٣٢ و = 4000000000.
    ط٦٤ ز = -1.

    صحيح ا = ت + 10.
    اطبع ا.

    ط٨ ح = ا.
    اطبع ح.

    إذا (ز > 0) اطبع 1. وإلا اطبع 0.
    اطبع ز / 2.
    اطبع ز % 2.

    اطبع س + 1.
    اطبع و + 1.

    إرجع 0.
}
