// RUN: compile-only
// يتحقق هذا الاختبار من صلاحية عقود ترويسات الواجهة الأمامية المكتوبة بباء مع التضمين المتكرر.

#تضمين "src/frontend/parser.baahd"
#تضمين "src/frontend/analysis.baahd"

صحيح الرئيسية() {
    تعداد نوع_عقدة_باء نوع_عقدة = نوع_عقدة_باء:برنامج.
    تعداد نوع_بيانات_باء نوع_بيانات = نوع_بيانات_باء:صحيح_كامل.
    تعداد عملية_ثنائية_باء عملية_ثنائية = عملية_ثنائية_باء:جمع.
    تعداد عملية_أحادية_باء عملية_أحادية = عملية_أحادية_باء:سالب.

    إذا (نوع_عقدة != نوع_عقدة_باء:برنامج) {
        إرجع ١.
    }
    إذا (نوع_بيانات != نوع_بيانات_باء:صحيح_كامل) {
        إرجع ٢.
    }
    إذا (عملية_ثنائية != عملية_ثنائية_باء:جمع) {
        إرجع ٣.
    }
    إذا (عملية_أحادية != عملية_أحادية_باء:سالب) {
        إرجع ٤.
    }

    عقدة_باء جذر = عدم.
    إذا (جذر != عدم) {
        إرجع ٥.
    }

    إرجع ٠.
}
