// RUN: compile-only
// يتحقق هذا الاختبار من مسار تعريف أسماء الأنواع البديلة داخل شريحة المحلل المكتوبة بباء.

نوع مؤشر_عدد_تصريح = صحيح*.
نوع عملية_تصريح = دالة(صحيح، صحيح) -> صحيح.
نوع عملية_ثانية_تصريح = عملية_تصريح.

صحيح اجمع_اسم_نوع(صحيح أ، صحيح ب) {
    إرجع أ + ب.
}

صحيح الرئيسية() {
    صحيح قيمة = ٧.
    مؤشر_عدد_تصريح مؤشر = &قيمة.
    عملية_ثانية_تصريح عملية = اجمع_اسم_نوع.

    إذا (*مؤشر != ٧) { إرجع ١. }
    إذا (عملية(٢، ٣) != ٥) { إرجع ٢. }

    إرجع ٠.
}
