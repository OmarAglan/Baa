// RUN: compile-only
// يتحقق هذا الاختبار من تفرع تصريحات المستوى الأعلى داخل شريحة المحلل المكتوبة بباء.

تعداد طور_تصريح {
    أول،
    ثاني،
}

هيكل زوج_تصريح {
    صحيح أ.
    صحيح ب.
}

اتحاد قيمة_تصريح {
    صحيح رقم.
    ط٨ علم.
}

نوع رقم_تصريح = صحيح.

ثابت ساكن صحيح حد_تصريح = ٧.
ساكن صحيح مخزن_تصريح[٢] = {١، ٢}.
رقم_تصريح قيمة_تصريح = ٣.

صحيح اجمع_تصريح(صحيح أ، صحيح ب) {
    إرجع أ + ب.
}

صحيح الرئيسية() {
    تعداد طور_تصريح طور = طور_تصريح:أول.
    هيكل زوج_تصريح زوج.
    اتحاد قيمة_تصريح قيمة.

    زوج:أ = حد_تصريح.
    زوج:ب = قيمة_تصريح.
    قيمة:رقم = اجمع_تصريح(زوج:أ، زوج:ب).

    إذا (طور != طور_تصريح:أول) { إرجع ١. }
    إذا (مخزن_تصريح[٠] != ١) { إرجع ٢. }
    إذا (قيمة:رقم != ١٠) { إرجع ٣. }

    إرجع ٠.
}
