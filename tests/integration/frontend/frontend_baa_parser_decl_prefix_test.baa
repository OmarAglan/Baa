// RUN: compile-only
// يتحقق هذا الاختبار من طلب شريحة باء لمقدمة التصريح غير البديل قبل تسليم الذيل إلى C.

تعداد طور_مقدمة {
    أول،
    ثان،
}

هيكل زوج_مقدمة {
    صحيح أ.
    صحيح ب.
}

اتحاد قيمة_مقدمة {
    صحيح رقم.
    ط٨ علم.
}

صحيح اجمع_مقدمة(صحيح أ، صحيح ب) {
    إرجع أ + ب.
}

صحيح* مؤشر_مقدمة.
دالة(صحيح، صحيح) -> صحيح عملية_مقدمة.
صحيح أرقام_مقدمة[٣] = {١، ٢، ٣}.

صحيح الرئيسية() {
    هيكل زوج_مقدمة زوج.
    اتحاد قيمة_مقدمة قيمة.
    تعداد طور_مقدمة طور = طور_مقدمة:ثان.

    زوج:أ = أرقام_مقدمة[٠].
    عملية_مقدمة = اجمع_مقدمة.
    زوج:ب = عملية_مقدمة(٢، ٣).
    قيمة:رقم = اجمع_مقدمة(زوج:أ، زوج:ب).
    مؤشر_مقدمة = &قيمة:رقم.

    إذا (طور != طور_مقدمة:ثان) { إرجع ١. }
    إذا (*مؤشر_مقدمة != ٦) { إرجع ٢. }

    إرجع ٠.
}
