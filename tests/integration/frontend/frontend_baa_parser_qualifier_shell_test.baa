// RUN: runtime
// يتحقق هذا الاختبار من امتلاك شريحة باء لتتابع مؤهلات تصريحات المستوى الأعلى.

ثابت ساكن صحيح حد_أول = ٧.
ساكن ثابت صحيح حد_ثان = ٣.
ساكن صحيح مخزن_مؤهل[٢] = {٢، ٥}.

صحيح الرئيسية() {
    إذا (حد_أول != ٧) { إرجع ١. }
    إذا (حد_ثان != ٣) { إرجع ٢. }
    إذا (مخزن_مؤهل[٠] != ٢) { إرجع ٣. }
    إذا (مخزن_مؤهل[١] != ٥) { إرجع ٤. }

    إرجع ٠.
}
