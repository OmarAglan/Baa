// RUN: compile-only
// FLAGS: -S
// EXPECT-ASM: rdtsc
// EXPECT-ASM: nop

صحيح قراءة_عداد() {
    ط٣٢ منخفض = ٠.
    ط٣٢ مرتفع = ٠.

    مجمع {
        "rdtsc"
        : "=a"(منخفض)، "=d"(مرتفع)
    }

    إرجع كـ<صحيح>(منخفض) + كـ<صحيح>(مرتفع).
}

صحيح الرئيسية() {
    مجمع {
        "nop"
    }

    صحيح قيمة = قراءة_عداد().
    إذا (قيمة < ٠) {
        إرجع ١.
    }
    إرجع ٠.
}
