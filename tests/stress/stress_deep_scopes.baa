// RUN: expect-pass,runtime

صحيح الرئيسية() {
    صحيح مجموع = ٠.

    لكل (صحيح ع = ٠؛ ع < ٢٠؛ ع = ع + ١) {
        صحيح مستوى١ = ع + ١.
        {
            صحيح مستوى٢ = مستوى١ + ٢.
            {
                صحيح مستوى٣ = مستوى٢ + ٣.
                {
                    صحيح مستوى٤ = مستوى٣ + ٤.
                    {
                        صحيح مستوى٥ = مستوى٤ + ٥.
                        مجموع = مجموع + مستوى٥.
                    }
                }
            }
        }
    }

    إذا (مجموع <= ٠) {
        إرجع ١.
    }

    إرجع ٠.
}
