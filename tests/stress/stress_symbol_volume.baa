// RUN: expect-pass,runtime

صحيح جمع_دفعة(صحيح أساس) {
    صحيح س٠ = أساس + ٠.
    صحيح س١ = أساس + ١.
    صحيح س٢ = أساس + ٢.
    صحيح س٣ = أساس + ٣.
    صحيح س٤ = أساس + ٤.
    صحيح س٥ = أساس + ٥.
    صحيح س٦ = أساس + ٦.
    صحيح س٧ = أساس + ٧.
    صحيح س٨ = أساس + ٨.
    صحيح س٩ = أساس + ٩.
    صحيح س١٠ = أساس + ١٠.
    صحيح س١١ = أساس + ١١.
    صحيح س١٢ = أساس + ١٢.
    صحيح س١٣ = أساس + ١٣.
    صحيح س١٤ = أساس + ١٤.
    صحيح س١٥ = أساس + ١٥.
    صحيح س١٦ = أساس + ١٦.
    صحيح س١٧ = أساس + ١٧.
    صحيح س١٨ = أساس + ١٨.
    صحيح س١٩ = أساس + ١٩.

    إرجع س٠ + س١ + س٢ + س٣ + س٤ + س٥ + س٦ + س٧ + س٨ + س٩ +
          س١٠ + س١١ + س١٢ + س١٣ + س١٤ + س١٥ + س١٦ + س١٧ + س١٨ + س١٩.
}

صحيح الرئيسية() {
    صحيح مجموع = ٠.
    لكل (صحيح د = ٠؛ د < ٥٠؛ د = د + ١) {
        مجموع = مجموع + جمع_دفعة(د).
    }

    إذا (مجموع <= ٠) {
        إرجع ١.
    }
    إرجع ٠.
}
