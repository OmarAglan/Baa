// RUN: expect-pass,runtime

صحيح احسب_المجموع_العربي(صحيح حد) {
    صحيح الناتج_الإجمالي = ٠.
    لكل (صحيح فهرس_داخلي = ٠؛ فهرس_داخلي < حد؛ فهرس_داخلي = فهرس_داخلي + ١) {
        الناتج_الإجمالي = الناتج_الإجمالي + فهرس_داخلي.
    }
    إرجع الناتج_الإجمالي.
}

صحيح الرئيسية() {
    نص رسالة_ترحيب = "مرحبا بباء".
    صحيح قيمة_١ = احسب_المجموع_العربي(١٠).
    صحيح قيمة_٢ = احسب_المجموع_العربي(٢٠).
    صحيح مجموع_نهائي = قيمة_١ + قيمة_٢.

    إذا (رسالة_ترحيب[٠] == ٠) {
        إرجع ١.
    }

    إذا (مجموع_نهائي <= ٠) {
        إرجع ٢.
    }

    إرجع ٠.
}
